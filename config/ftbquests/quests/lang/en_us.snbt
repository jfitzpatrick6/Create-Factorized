	chapter.4F034AC551FDF0D9.title: "Security & Munitions"
	quest.052E8E06FC254C16.quest_desc: [
		"&aSecurity wing online!&r Your factory floor is lit, claimed, and producing mob drops."
		""
		"From here the &cmunitions branch&r is optional. It consumes byproducts from your ore lines:"
		"&7• &ftfmg:sulfur_dust&7 — lead/nickel 3× washing"
		"&7• &ftfmg:nitrate_dust&7 — crush dirt/gravel (TFMG route)"
		"&7• &fcoal coke&7 — petrochem coking (mid-game)"
		""
		"Skip this entire branch if you only want to build — that's valid."
	]
	quest.052E8E06FC254C16.quest_subtitle: "Security complete — munitions optional"
	quest.052E8E06FC254C16.title: "Security Wing Complete"
	quest.0656D6CC15EE2E94.quest_desc: [
		"Sulfur is the first propellant input. Wash &ecrushed lead or nickel&r in a Create splashing setup."
		""
		"Each wash pass has a chance to output &ftfmg:sulfur_dust&r alongside nuggets — stockpile it for gunpowder."
		""
		"&7CoE Deposits lead/nickel veins also return sulfur from drilling."
	]
	quest.0656D6CC15EE2E94.quest_subtitle: "Tier 1 — wash byproduct"
	quest.0656D6CC15EE2E94.title: "Sulfur from Washing"
	quest.0FBB2583A25871DF.quest_desc: [
		"Gate the revolver on &eTFMG steel mechanisms&r — not parallel CGS steel."
		""
		"Mechanical crafter pattern uses:"
		"&7• Steel mechanism (replaces loose steel ingot)"
		"&7• Brass + steel plates + wood stock"
		""
		"Viable after lead 3× washing and brass pressing."
	]
	quest.0FBB2583A25871DF.quest_subtitle: "Tier 2 — first firearm"
	quest.0FBB2583A25871DF.title: "Steel-Mechanism Revolver"
	quest.22A247E65899B24C.quest_desc: [
		"High-explosive shells need &eguncotton&r — nitrate paper in a mixer."
		""
		"&eMixer:&r paper + gunpowder + nitro acidifier (redstone dust) + water → guncotton"
		""
		"Compact &73× guncotton&r → packed guncotton for AP and HE shell assembly."
	]
	quest.22A247E65899B24C.quest_subtitle: "Tier 3 — HE filler prep"
	quest.22A247E65899B24C.title: "Guncotton Line"
	quest.246C43CEF7D0586A.quest_desc: [
		"Armor-piercing shells add a &ecast iron&r cap and packed guncotton filler."
		""
		"Run the pack &esequenced assembly&r line — deploy cast iron, guncotton, and slab, then press."
		""
		"&7Recipe ID: &fkubejs:explosives/sequenced_assembly/ap_shell"
	]
	quest.246C43CEF7D0586A.quest_subtitle: "Tier 3 — AP shells"
	quest.246C43CEF7D0586A.title: "AP Shell Factory"
	quest.2F37B9F6D54887BD.quest_desc: [
		"The &egatling&r requires &ftfmg:steel_mechanism&r in the mechanical crafter — mid/late steel age."
		""
		"Gatling drum adds &fcontrol unit&r + &fcopper spool&r for sustained fire factory theming."
	]
	quest.2F37B9F6D54887BD.quest_subtitle: "Tier 3 — heavy personal weapon"
	quest.2F37B9F6D54887BD.title: "Gatling Battery"
	quest.316AD3397418B28B.quest_desc: [
		"The &enailgun&r gates on &fkubejs:control_unit&r — same item that unlocks deployers and smart pipes."
		""
		"Pneumatic factory tool: copper backtank + fluid valves + control unit + brass frame."
	]
	quest.316AD3397418B28B.quest_subtitle: "Tier 3 — electronics weapon"
	quest.316AD3397418B28B.title: "Control-Unit Nailgun"
	quest.342A419A922CE71B.quest_desc: [
		"Brass-cased ammunition needs &efactory propellant&r — the pack's gated smokeless powder."
		""
		"&eHeated mixer:&r"
		"&72×&r sulfur + &72×&r nitrate + coke dust + water → &a4 factory propellant"
		""
		"Revolver, gatling, and shotgun &esequenced assembly&r blank lines deploy this item instead of raw gunpowder."
	]
	quest.342A419A922CE71B.quest_subtitle: "Tier 2 — brass ammo chemistry"
	quest.342A419A922CE71B.title: "Factory Propellant"
	quest.3E9C12C3A1A77329.quest_desc: [
		"&eFTB Chunks&r lets your team claim cooperative build zones."
		""
		"Open the map (&bdefault: M&r), select a chunk, and claim it for your team. Claimed chunks are your &asafe factory floor&r — not a PvP arena."
		""
		"Claim the area around your main machines so chunk loaders and builds stay protected on the friend server."
	]
	quest.3E9C12C3A1A77329.quest_subtitle: "Step 2 — claim your base"
	quest.3E9C12C3A1A77329.title: "Claim Your Chunk"
	quest.41C2F3AF2B91FC12.quest_desc: [
		"Incendiary shotgun shells swap blaze powder for a &fgasoline bucket&r — petrochem integration."
		""
		"Run the shotgun blank line, then deploy gasoline on the incendiary assembly step."
	]
	quest.41C2F3AF2B91FC12.quest_subtitle: "Tier 3 — petrochem ammo"
	quest.41C2F3AF2B91FC12.title: "Incendiary Shotgun Rounds"
	quest.42AC290DBC86C2C3.quest_desc: [
		"Piercing rounds deploy &dovercharged iron&r from the electronics line instead of steel nuggets."
		""
		"Premium ammo tier — pairs CNA energising with your brass blank plant."
	]
	quest.42AC290DBC86C2C3.quest_subtitle: "Tier 3 — electronics ammo"
	quest.42AC290DBC86C2C3.title: "Piercing Ammunition"
	quest.43F4B75443DAFACA.quest_desc: [
		"Shrapnel shells combine &eshot balls&r with &fpacked gunpowder&r in sequenced assembly."
		""
		"Less armor penetration than AP — more area saturation. Good for display batteries and clearing caves."
	]
	quest.43F4B75443DAFACA.quest_subtitle: "Tier 3 — shrapnel shells"
	quest.43F4B75443DAFACA.title: "Shrapnel Shell Factory"
	quest.4829C15DE34003C9.quest_desc: [
		"Pack gunpowder requires chemistry — vanilla charcoal crafts are removed."
		""
		"&eHeated mixer:&r"
		"&72×&r sulfur dust + &72×&r nitrate dust + &7250 mB water&r → &a4 gunpowder"
		""
		"Zinc washing also drops gunpowder. Supplement with:"
		"&7gunpowder + charcoal → 2 gunpowder&r (heated)"
	]
	quest.4829C15DE34003C9.quest_subtitle: "Tier 1 — chemistry powder"
	quest.4829C15DE34003C9.title: "Chemistry Gunpowder"
	quest.484E0D6E17F78761.quest_desc: [
		"Factory &amob infrastructure&r means automating drops — not hunting mobs by hand."
		""
		"Build a simple dark-room farm:"
		"&7• Water streams push spawns to a kill spot"
		"&7• &eEncased Fan&r blows mobs into lava, a deployer blade, or a crushing wheel"
		"&7• Collect loot in a chest at the end of the line"
		""
		"&bNo kill quest&r — just pull &f16 rotten flesh&r from your farm chest to prove the line works."
	]
	quest.484E0D6E17F78761.quest_subtitle: "Step 3 — mob drop line"
	quest.484E0D6E17F78761.title: "Mob Farm Chest"
	quest.4DE4F6EEF8FB78A1.quest_desc: [
		"Saltpeter in this pack is &ftfmg:nitrate_dust&r (canonical — CGS niter converts automatically)."
		""
		"Early source: run &edirt or gravel&r through crushing wheels — TFMG crushes yield nitrate dust."
		""
		"Later, pair sulfur + nitrate in heated mixers for all propellant tiers."
	]
	quest.4DE4F6EEF8FB78A1.quest_subtitle: "Tier 1 — nitrate supply"
	quest.4DE4F6EEF8FB78A1.title: "Nitrate Stockpile"
	quest.54F7EE91311D9472.quest_desc: [
		"Cast a &eCreate Big Cannons&r breech to start a display battery."
		""
		"Use &funified steel and cast iron&r from TFMG — duplicate CBC/CGS ingots convert automatically."
		""
		"Load shells with propellant bags or cartridges, aim away from your claimed chunks, and fire for fun."
	]
	quest.54F7EE91311D9472.quest_subtitle: "Tier 4 — artillery hardware"
	quest.54F7EE91311D9472.title: "Cannon Breech Cast"
	quest.58A6ACDB12ED5279.quest_desc: [
		"Mobs spawn in the dark. Light your factory floor so you can build without surprise visitors."
		""
		"Place &etorches&r, &elanterns&r, or Create &alamps&r along walkways and machine halls."
		""
		"&7Light level 7+ on floors = no hostile spawns."
	]
	quest.58A6ACDB12ED5279.quest_subtitle: "Step 1 — light the floor"
	quest.58A6ACDB12ED5279.title: "Light the Factory"
	quest.5A62058E551370BB.quest_desc: [
		"Automate solid shot on a &esequenced assembly&r line:"
		""
		"&71.&r Deploy lead nuggets onto iron body"
		"&72.&r Deploy steel heavy plate"
		"&73.&r Deploy wooden slab base"
		"&74.&r Press to finish"
		""
		"Uses &f3× wash lead nuggets&r — not 5× ingots — so ammo doesn't starve your metal lines."
	]
	quest.5A62058E551370BB.quest_subtitle: "Tier 3 — SA shell line"
	quest.5A62058E551370BB.title: "Solid Shot Assembly"
	quest.5A8EFF9FDCA38A6F.quest_desc: [
		"&aMunitions factory online!&r You built the optional security wing and a full propellant → shell pipeline."
		""
		"&7Sulfur/nitrate → propellant → CGS brass ammo + CBC shells → cannon breech"
		""
		"Use it to offload excess steel and lead from your 3× lines, decorate the megabase with artillery, and run co-op clearance sessions."
		""
		"&eNothing here gates the nuclear reactor or building chapters.&r Go build when ready."
	]
	quest.5A8EFF9FDCA38A6F.quest_subtitle: "Capstone — security + artillery"
	quest.5A8EFF9FDCA38A6F.title: "Munitions Capstone"
	quest.5CD29C41A6D1A26F.quest_desc: [
		"&eOptional advanced&r — once your mob farm runs reliably, route drops through &dCreate Enchantment Industry&r for XP fluid."
		""
		"Deployer kills → XP fluid → basin/tank storage → tool enchanting beside your machines."
		""
		"&7Skip this if you're not ready for fluid XP yet — it is not required anywhere in the pack."
	]
	quest.5CD29C41A6D1A26F.quest_subtitle: "Optional — CEI xp fluid"
	quest.5CD29C41A6D1A26F.title: "Enchantment Industry (Optional)"
	quest.650F4EBEB6D3CFE0.quest_desc: [
		"&eCreate Gunsmithing&r cartridges use lead nuggets and gunpowder — both from factory lines."
		""
		"Craft manually or run the &esequenced assembly&r paper cartridge line:"
		"&7paper → deploy gunpowder → deploy lead nugget"
		""
		"Brass ammo plants use &fkubejs:factory_propellant&r — sulfur + nitrate + coke dust, not zinc gunpowder alone."
	]
	quest.650F4EBEB6D3CFE0.quest_subtitle: "Side route — CGS ammo"
	quest.650F4EBEB6D3CFE0.title: "Paper Cartridges"
	quest.6743B591C2ADB6E6.quest_desc: [
		"Advanced HE chemistry replaces the blaze shortcut."
		""
		"&eHeated mixer:&r sulfur + nitrate + coal coke + &fsulfuric acid&r → congealed nitro"
		""
		"Smelt congealed nitro → hardened nitro → mill to nitropowder for premium AP/HE filler."
	]
	quest.6743B591C2ADB6E6.quest_subtitle: "Tier 4 — nitro chemistry"
	quest.6743B591C2ADB6E6.title: "Congealed Nitro"
	quest.6C2EAD8E97B99B45.quest_desc: [
		"High-explosive shells pack &epacked guncotton&r into an iron body — the big boom option."
		""
		"Same SA pattern as AP, without the cast iron cap."
		""
		"Great for co-op site clearance before expanding into new chunks."
	]
	quest.6C2EAD8E97B99B45.quest_subtitle: "Tier 3 — HE shells"
	quest.6C2EAD8E97B99B45.title: "HE Shell Factory"
	quest.728C8681F84E44B2.quest_desc: [
		"&eMunitions are optional&r — guns and cannons never gate recipes, power, or progression."
		""
		"This chapter has two parts:"
		"&71)&r &aSecurity wing&r — keep your factory floor safe (lighting, chunk claims, mob drops)"
		"&72)&r &cMunitions factory&r — turn ore-wash chemistry into CGS ammo and CBC shells"
		""
		"Combat is &elow priority&r. Think of this as co-op toys and a resource sink for your megabase — not a second progression tree."
		""
		"&7Tip: Search JEI for &fkubejs:explosives&7 to see pack propellant recipes."
	]
	quest.728C8681F84E44B2.quest_subtitle: "Optional security + artillery"
	quest.728C8681F84E44B2.title: "Welcome — Security Wing"
	quest.747AD5FD60562407.quest_desc: [
		"Cannon propellant needs the &epetrochem coke age&r."
		""
		"&eHeated mixer:&r"
		"&72×&r sulfur + &72×&r nitrate + &fcoal coke&r + water → &a2 packed gunpowder"
		""
		"Packed gunpowder feeds CBC propellant bags and shrapnel shells."
	]
	quest.747AD5FD60562407.quest_subtitle: "Tier 2 — cannon propellant"
	quest.747AD5FD60562407.title: "Industrial Packed Gunpowder"
	quest.783AA06A6CFFF511.quest_desc: [
		"Press brass sheet with revolver press forms, deploy factory propellant, then deploy lead nuggets."
		""
		"&7Blank line → &fcgs:round_revolver_blank&7 → &fcgs:round_revolver"
		""
		"This is your first full &aCreate SA ammo factory&r — scale it beside the shell line."
	]
	quest.783AA06A6CFFF511.quest_subtitle: "Tier 2 — revolver rounds"
	quest.783AA06A6CFFF511.title: "Revolver Round Plant"
	quest.7F00D00000000010.quest_desc: [
		"&eFood in this pack is optional&r — it never gates recipes, power, or progression."
		""
		"The goal is simple: &afuel long factory sessions&r with light buffs that &bhelp&r mining and building, not replace them."
		""
		"This chapter walks you from a basic wheat farm through Create-powered meal production and the &dNourished&r nutrition system."
		""
		"&7Tip: Open JEI and search &f@kubejs&7 anytime to see custom factory meals."
	]
	quest.7F00D00000000010.quest_subtitle: "Optional canteen progression"
	quest.7F00D00000000010.title: "Welcome to the Factory Canteen"
	quest.7F00D00000000011.quest_desc: [
		"&dNourished&r tracks five nutrient bars: &cProteins&r, &aVegetables&r, &6Grains&r, &dFruits&r, and &9Dairy&r."
		""
		"Eat varied foods to fill them. Bars slowly decay over time — keep eating during long builds."
		""
		"&aAbove 75%&r on a nutrient: bonus effects kick in."
		"&cBelow 25%&r: light penalties (e.g. mining fatigue when protein is low)."
		""
		"&bPack bonuses at 75%+:&r"
		"&7• Proteins → Haste (mining speed)"
		"&7• Grains → Speed (movement)"
		"&7• All nutrients high → Regeneration + Health Boost"
		""
		"Press your &dNourished diet key&r (check Controls) to open the nutrition screen."
	]
	quest.7F00D00000000011.quest_subtitle: "Understand your nutrition HUD"
	quest.7F00D00000000011.title: "Nourished — Session Buffs"
	quest.7F00D00000000012.quest_desc: [
		"Every food line starts with &astaple crops&r. You can hand-farm at first — automation comes next."
		""
		"Wheat becomes &ecanonical flour and dough&r via Create (not duplicate FD items)."
		"Carrots and potatoes feed hearty broths and stews later."
		""
		"&7Canonical items in this pack:&r"
		"&7• Flour → &fcreate:wheat_flour"
		"&7• Dough → &fcreate:dough"
		"&7• Bread slices / toast → &ffarmersdelight_extended&7 variants"
	]
	quest.7F00D00000000012.quest_subtitle: "Stock the pantry"
	quest.7F00D00000000012.title: "Staple Crop Stockpile"
	quest.7F00D00000000013.quest_desc: [
		"Route wheat through a &eCreate Millstone&r (or crushing wheels) to get &fcreate:wheat_flour&r."
		""
		"This is the &aonly flour&r you need — other mod flours convert to it automatically."
		""
		"&7JEI: search &fcreate:wheat_flour&7 to see all routes."
	]
	quest.7F00D00000000013.quest_subtitle: "Tier 1 — milling"
	quest.7F00D00000000013.title: "Mill to Flour"
	quest.7F00D00000000014.quest_desc: [
		"Combine flour and water in a &eMechanical Mixer&r to produce &fcreate:dough&r."
		""
		"Dough is the base for bread, battered foods, and many FD Extended recipes."
	]
	quest.7F00D00000000014.quest_subtitle: "Tier 1 — mixing"
	quest.7F00D00000000014.title: "Knead the Dough"
	quest.7F00D00000000015.quest_desc: [
		"Farmer's Delight prep starts at the &eCutting Board&r with any knife from the unified knife tag."
		""
		"Slice meat, fish, and veg here before they go into the cooking pot."
		""
		"&7Pack unifies knives from FD, MoreDelight, and Ends Delight into one tag."
	]
	quest.7F00D00000000015.quest_subtitle: "Tier 2 — manual prep"
	quest.7F00D00000000015.title: "Cutting Board Prep"
	quest.7F00D00000000016.quest_desc: [
		"&eSlice and Dice&r adds a Create &aSlicer&r — automate cutting board recipes on a contraption."
		""
		"Place a cutting board under the slicer, feed ingredients on a belt, and let deployers do the prep."
		""
		"&7Knife durability applies — keep a spare knife in the system."
	]
	quest.7F00D00000000016.quest_subtitle: "Tier 2 — automated prep"
	quest.7F00D00000000016.title: "Slicer Station"
	quest.7F00D00000000017.quest_desc: [
		"The &eCooking Pot&r is the heart of Farmer's Delight meal crafting."
		""
		"Toss ingredients in, add a container (bowl/plate), and cook over heat."
		""
		"&eCreate Central Kitchen&r lets you automate pot recipes with deployers and blaze burners on moving contraptions — check JEI for your target meal."
	]
	quest.7F00D00000000017.quest_subtitle: "Tier 2 — hot meals"
	quest.7F00D00000000017.title: "Cooking Pot Online"
	quest.7F00D00000000018.quest_desc: [
		"&eBotany Pots&r grow crops on demand — perfect for spice ingredients beside your factory."
		""
		"&aExpanded Delight&r crops used in this pack:"
		"&7• Chili pepper — desert/savanna heat"
		"&7• Cinnamon — tree crop (Botany Trees)"
		"&7• Cranberries — needs water soil"
		"&7• Asparagus, peanuts — mid-game veg/protein"
		""
		"Plant one spice crop to unlock the seasoning line later."
	]
	quest.7F00D00000000018.quest_subtitle: "Tier 3 — spice inputs"
	quest.7F00D00000000018.title: "Spice Garden (Botany Pots)"
	quest.7F00D00000000019.quest_desc: [
		"Mount a &eMechanical Harvester&r on a contraption to automate crop collection."
		""
		"Pair with a deployer cobblegen or a simple flooded farm — wheat, carrots, and potatoes all work."
		""
		"Mob farms (deployer + fan) also feed protein lines for stews."
	]
	quest.7F00D00000000019.quest_subtitle: "Tier 1 — farm automation"
	quest.7F00D00000000019.title: "Harvester Contraption"
	quest.7F00D0000000001A.quest_desc: [
		"Toast and bread slices are &acanonical&r through FD Extended."
		""
		"Route bread through a smoker or campfire, or use Create smokers on belts."
		""
		"Toast is an ingredient in the &eVein Scout Snack&r and &eFactory Lunchbox&r later."
	]
	quest.7F00D0000000001A.quest_subtitle: "Side route — bakery"
	quest.7F00D0000000001A.title: "Toast Production"
	quest.7F00D0000000001B.quest_desc: [
		"Automate cheese with a &eheated mixer&r: 1000 mB milk → Fresh Cheese."
		""
		"This pack fixes broken FD Extended Create recipes — battered foods, cheese, ice cream, and mochi all work in JEI now."
		""
		"Fresh cheese feeds the &aaged cheese&r luxury line."
	]
	quest.7F00D0000000001B.quest_subtitle: "Tier 2 — dairy automation"
	quest.7F00D0000000001B.title: "Fresh Cheese (Create Mixer)"
	quest.7F00D0000000001C.quest_desc: [
		"Combine automation-era ingredients into &efortified seasoning&r:"
		""
		"&7• 1× chili pepper"
		"&7• 1× cinnamon stick"
		"&7• 50 mB lubrication oil (petrochem byproduct)"
		""
		"Heated mixing. This is the &aspice gate&r for factory worker meals — one batch seasons many stews."
	]
	quest.7F00D0000000001C.quest_subtitle: "Tier 3 — spice processing"
	quest.7F00D0000000001C.title: "Fortified Seasoning"
	quest.7F00D0000000001D.quest_desc: [
		"The &eOre Worker Stew&r is your mining-session meal."
		""
		"Heated mixer: cooked beef, carrots, fortified seasoning, water."
		""
		"High &cprotein&r and &aveg&r — pushes Nourished bars above 75% for &bHaste&r while you mine or run ore processing."
		""
		"&7This complements — not replaces — your 3×/5× ore lines."
	]
	quest.7F00D0000000001D.quest_subtitle: "Tier 4 — mining buff meal"
	quest.7F00D0000000001D.title: "Ore Worker Stew"
	quest.7F00D0000000001E.quest_desc: [
		"&eHearty Broth&r simmers in a heated basin with a long processing time."
		""
		"Bones, potatoes, asparagus, and water — a regen-friendly meal for long building sessions."
		""
		"Pairs well with the &aall-nutrients-high&r regen bonus from Nourished."
	]
	quest.7F00D0000000001E.quest_subtitle: "Tier 4 — regen meal"
	quest.7F00D0000000001E.title: "Hearty Broth"
	quest.7F00D0000000001F.quest_desc: [
		"Compact a quick scouting snack: toast, cranberries, and peanuts."
		""
		"High &6grains&r and &dfruits&r — great before a vein-scouting run or Terralith excursion."
		""
		"At 75%+ grains you get &bSpeed&r from Nourished."
	]
	quest.7F00D0000000001F.quest_subtitle: "Tier 4 — movement snack"
	quest.7F00D0000000001F.title: "Vein Scout Snack"
	quest.7F00D00000000020.quest_desc: [
		"Eat any &efactory meal&r and check your Nourished HUD."
		""
		"Goal: keep nutrients &aabove 75%&r during a work session."
		""
		"&bActive bonuses to aim for:&r"
		"&7• Haste (proteins) — faster mining"
		"&7• Speed (grains) — faster movement"
		"&7• Regen (all high) — sustain during builds"
		""
		"Food is &eoptional&r — but a stocked canteen makes megafactory nights much smoother."
	]
	quest.7F00D00000000020.quest_subtitle: "Put buffs to work"
	quest.7F00D00000000020.title: "Nutrition Online"
	quest.7F00D00000000021.quest_desc: [
		"Age fresh cheese in a &eheated basin&r with long processing time."
		""
		"2× fresh cheese → 1× &eAged Cheese Wheel&r"
		""
		"Cut the wheel on a slicer or cutting wheel for slices used in the lunchbox."
	]
	quest.7F00D00000000021.quest_subtitle: "Tier 5 — aging"
	quest.7F00D00000000021.title: "Aged Cheese Line"
	quest.7F00D00000000022.quest_desc: [
		"Press cocoa, sugar, and Create chocolate into a &eluxury chocolate bar&r."
		""
		"High dairy + grains + fruits in Nourished — a dessert buff for late-night building."
	]
	quest.7F00D00000000022.quest_subtitle: "Tier 5 — dessert"
	quest.7F00D00000000022.title: "Luxury Chocolate Bar"
	quest.7F00D00000000023.quest_desc: [
		"Package a full shift meal via &esequenced assembly&r:"
		""
		"&71.&r Bread slice + aged cheese (deployer)"
		"&72.&r Add toast layer (deployer)"
		"&73.&r Press to seal"
		""
		"Output: &eFactory Lunchbox&r — balanced nutrients for marathon factory sessions."
	]
	quest.7F00D00000000023.quest_subtitle: "Tier 5 — packaged lunch"
	quest.7F00D00000000023.title: "Factory Lunchbox"
	quest.7F00D00000000024.quest_desc: [
		"&aCanteen complete!&r You now have a full food automation line:"
		""
		"&7Farm → mill → mix → cook → spice → factory meals → luxury lunchbox"
		""
		"Keep the canteen stocked beside your ore processing and building stone lines. Return here anytime food recipes confuse you — JEI is always the source of truth."
		""
		"&eThis chapter never gates progression.&r Go build the reactor when ready."
	]
	quest.7F00D00000000024.quest_subtitle: "Capstone — shift meal master"
	quest.7F00D00000000024.title: "Canteen Capstone"
	task.0157156D0E155BB1.title: "I claimed a factory chunk with FTB Chunks"
	task.0A7ED4D1B1E5F102.title: "I understand the optional CEI mob-xp line"
	task.290146DF57385BB0.title: "Security wing + munitions line complete"
	task.681CC6540A9C9BB6.title: "Security wing is set up — munitions are optional"
	task.787937664EB59E73.title: "Read the security briefing"
	task.7F00D00000000100.title: "Read the canteen briefing"
	task.7F00D00000000101.title: "I know how Nourished works"
	task.7F00D00000000114.title: "I ran a session with factory meals + Nourished"
	quest.5A8EFF9FDCA38A6E.quest_desc: [
		"&eTier 3 personal weapons&r — pick your factory sidearm path."
		""
		"Complete &fone&r of:"
		"&7• &fControl-Unit Nailgun&r — electronics-gated pneumatic tool"
		"&7• &fGatling Battery&r — steel-mechanism sustained fire"
		""
		"Both branch from &fRevolver Round Plant&r. Artillery (breech + capstone) does not require this milestone."
	]
	quest.5A8EFF9FDCA38A6E.quest_subtitle: "Nailgun or gatling — your pick"
	quest.5A8EFF9FDCA38A6E.title: "Personal Weapons Fork"
	quest.8F01B0000000002C.quest_desc: [
		"&eOptional&r — the &ftfmg:fireproof_chemical_vat&r unlocks superheated petrochemical recipes in a multiblock vat."
		""
		"Heavy-oil &fcoke coking&r (petrochem chapter) and several cracking routes need this block before you scale late fuels."
		""
		"&7Not required for the reactor capstone&r — craft when you are ready to run vat chemistry beside your distillation tower."
	]
	quest.8F01B0000000002C.quest_subtitle: "Optional — vat multiblock"
	quest.8F01B0000000002C.title: "Fireproof Chemical Vat"
	task.290146DF57385BB1.title: "I built nailgun or gatling — personal weapons fork"
	quest.8F01E00000000010.quest_desc: [
		"&eOre metallurgy is the factory spine&r — every other wing drinks from the metal bus you build here."
		""
		"&7Tip:&r Use &fPin Quest&r on this welcome node so 2×/3×/5× steps stay on your HUD."
		""
		"This chapter walks the &apack ore tiers&r KubeJS enforces:"
		"&72×&r — smelt or blast &fcrushed raw&r ore (double ingot yield vs vanilla raw)"
		"&73×&r — splashing/washing crushed ore → &f27 nuggets&r (3 ingots) + RNG byproducts"
		"&75×&r — &aheated&r mechanical mixing with &f#tfmg:flux&r (limesand) + water (+ byproduct where listed)"
		""
		"&7Core metals:&r iron, copper, gold — full 2/3/5 ladder."
		"&7Modded metals:&r zinc stops at 3×; lead & nickel reach 5× with sulfur; lithium uses cooling fluid + optional vat electrolysis."
		""
		"&7Byproduct loops feed other chapters:&r"
		"&7• Iron wash → redstone → CNA energiser billets"
		"&7• Copper wash → clay"
		"&7• Gold 5× → quartz + ingot flood"
		"&7• Zinc wash → gunpowder → munitions"
		"&7• Lead/nickel wash → sulfur_dust → propellant & petrochem"
		"&7• Lithium → cooling_fluid_bottle → petrochem & diamond billet"
		""
		"&7Automation:&r Create Ore Excavation drilling replaces strip-mining for veins — pair with crushing/washing arrays."
		""
		"&7Quests never gate recipes&r — skip or rush branches; JEI always shows the truth."
		""
		"&7JEI:&r search &fkubejs:ore_processing&7 to preview every tier."
	]
	quest.8F01E00000000010.quest_subtitle: "Crush → wash → flux → drill"
	quest.8F01E00000000010.title: "Welcome — Ore Wing"
	quest.8F01E00000000011.quest_desc: [
		"Craft a &ecreate:crushing_wheel&r — the first machine every ore line shares."
		""
		"Mount two wheels on &fandesite casings&r with a shaft between them. Feed ores or raw ore blocks from a belt; collect &fcrushed raw&r on the output side."
		""
		"&7You need:&r andesite alloy age (wrench, casings, belts). No steel required yet."
		""
		"&71.&r Build a minimal crushing array (hand crank is fine for the first batch)"
		"&72.&r Route output into a chest — you'll smelt and wash from here"
		""
		"&7Common mistakes:&r"
		"&7• Feeding ingots — crush &fraw&r or &fore blocks&r only"
		"&7• Wheels spinning wrong direction — use wrench to flip"
		""
		"&7JEI:&r crush any &fminecraft:raw_iron&7 to see &fcreate:crushed_raw_iron&7 output."
	]
	quest.8F01E00000000011.quest_subtitle: "Step 1 — crushing wheels"
	quest.8F01E00000000011.title: "Crushing Wheel Online"
	quest.8F01E00000000012.quest_desc: [
		"Stockpile &f8× create:crushed_raw_iron&r — proof your crusher is fed and sorted."
		""
		"Crushed ore is the &eonly&r valid input for pack 2× smelting. Vanilla &fsmelting raw iron → 1 ingot&r is removed."
		""
		"&71.&r Crush iron ore, deepslate iron, or raw iron blocks"
		"&72.&r Bank crushed in a dedicated chest labeled &f2× feed&r"
		"&73.&r Optional: deployer + filtered funnel so only crushed enters smelters"
		""
		"&7Co-op tip:&r claim the crusher chunk early — wheel arrays are loud and laggy if unloaded."
	]
	quest.8F01E00000000012.quest_subtitle: "Step 2 — crushed feedstock"
	quest.8F01E00000000012.title: "Crushed Iron Bus"
	quest.8F01E00000000013.quest_desc: [
		"Run the &e2× tier&r — each crushed iron → &f2 iron ingots&r via furnace or blast furnace."
		""
		"Submit &f8 ingots&r to confirm smelting throughput (four crushed batches at 2×)."
		""
		"&71.&r Pipe crushed into furnaces or a single blast furnace for speed"
		"&72.&r Collect ingots — do &fnot&r skip to washing yet if your team is learning the tiers"
		""
		"&7Why 2× exists:&r doubles output before you invest fluid handling. Good bridge while andesite power is still hand-cranked."
		""
		"&7JEI:&r &fkubejs:ore_processing/iron_2x_smelting&7 and &firon_2x_blasting&7"
	]
	quest.8F01E00000000013.quest_subtitle: "Step 3 — 2× smelt"
	quest.8F01E00000000013.title: "Double Iron Yield"
	quest.8F01E00000000014.quest_desc: [
		"Build fluid handling for the &e3× wash tier&r — splashing recipes need a water source."
		""
		"Craft a &ecreate:item_drain&r (or pair with a &fcreate:spout&r over a belt). Crushed ore passes through flowing water to become nuggets."
		""
		"&71.&r Place item drain above a water block or connect a fluid pipe with water"
		"&72.&r Run crushed iron across the drain (belt + chute works)"
		"&73.&r Collect &fminecraft:iron_nugget&r — &f27 nuggets = 3 ingots&r per crushed"
		""
		"&7RNG byproduct:&r iron washing also drops &fredstone&r (~75% chance). Stock it — electronics wants tons."
		""
		"&7Common mistakes:&r"
		"&7• Splashing ingots — input must stay &fcrushed raw&r"
		"&7• No water — drain does nothing without a fluid source"
	]
	quest.8F01E00000000014.quest_subtitle: "Step 4 — splashing setup"
	quest.8F01E00000000014.title: "Washing Station"
	quest.8F01E00000000015.quest_desc: [
		"Prove the &e3× iron line&r: submit &f27 iron nuggets&r (one full wash batch) and &f8 redstone&r from byproduct stock."
		""
		"This is the first &abyproduct loop&r that pays downstream:"
		"&7Iron wash → redstone → CNA energiser billets (Electronics chapter)"
		""
		"&71.&r Wash crushed iron until you hold 27+ nuggets"
		"&72.&r Sift redstone into its own chest — label &fenergiser prep&r"
		"&73.&r Compact nuggets to ingots if your storage is tight (3 nuggets → 1 ingot)"
		""
		"&7Automation upgrade:&r fan + water mill → large washing pool, or sequential item drains on parallel belts."
		""
		"&7JEI:&r &fkubejs:ore_processing/iron_3x_splashing&7"
	]
	quest.8F01E00000000015.quest_subtitle: "Step 5 — 3× iron + redstone"
	quest.8F01E00000000015.title: "Triple Iron & Redstone"
	quest.8F01E00000000016.quest_desc: [
		"Stock &f8× tfmg:limesand&r — the pack's &e#tfmg:flux&r tag item for 5× mixing and petrochem chemistry."
		""
		"Limesand gates &aheated&r ore mixing, catalytic cracking, and several &fbuilding_stones&r recipes. Treat flux like a parallel resource, not trash."
		""
		"&71.&r Crush and wash ores until limesand accumulates (check JEI sources if low)"
		"&72.&r Store flux beside your mechanical mixer"
		"&73.&r Route excess to petrochem when that wing opens"
		""
		"&7Downstream:&r Petrochem's optional flux cracker and Architecture's calcite/deepslate lines both consume this tag."
	]
	quest.8F01E00000000016.quest_subtitle: "Step 6 — flux stockpile"
	quest.8F01E00000000016.title: "Limesand Flux Bus"
	quest.8F01E00000000017.quest_desc: [
		"Bring the &e5× tier&r online for iron — the pack ceiling for core metals."
		""
		"&7You need:&r"
		"&7• &ecreate:mechanical_mixer&r on a blaze burner (&aheated&r, not superheated)"
		"&7• &fcreate:crushed_raw_iron&r + &ftfmg:limesand&r + &f250 mB water&r + &fredstone&r (byproduct re-feed)"
		"&7• Output: &f5 iron ingots&r per batch"
		""
		"Submit the mixer (proof you built the cell) and &f10 iron ingots&r from 5× production."
		""
		"&71.&r Light a blaze burner under the mixer (empty lava or fuel program)"
		"&72.&r Pipe water with hoses or use bottles if early"
		"&73.&r Automate crushed + flux + redstone insertion — deployers or brass funnels"
		""
		"&7Common mistakes:&r"
		"&7• Unheated mixer — recipe won't start"
		"&7• Forgetting water fluid — heated mixing still needs 250 mB"
		""
		"&7JEI:&r &fkubejs:ore_processing/iron_5x_mixing&7"
	]
	quest.8F01E00000000017.quest_subtitle: "Step 7 — 5× heated iron"
	quest.8F01E00000000017.title: "Quintuple Iron Line"
	quest.8F01E00000000018.quest_desc: [
		"&eCopper branch&r — mirror the iron 3× wash on &fcreate:crushed_raw_copper&r."
		""
		"Submit &f27 copper nuggets&r and &f8 clay balls&r from washing byproduct (~50% per batch)."
		""
		"&7Copper wash → clay&r feeds building and bulk crafting; copper ingots feed brass and electronics."
		""
		"Copper also has a full 5× recipe (flux + water + clay re-feed) — extend when brass demand spikes."
		""
		"&7JEI:&r &fkubejs:ore_processing/copper_3x_splashing&7 and &fcopper_5x_mixing&7"
	]
	quest.8F01E00000000018.quest_subtitle: "Branch — copper 3×"
	quest.8F01E00000000018.title: "Copper Washing & Clay"
	quest.8F01E00000000019.quest_desc: [
		"&eGold branch&r — run the full ladder when you need energiser billet flood."
		""
		"3× wash drops &fquartz&r (~50%); 5× heated mixing uses crushed + flux + water + quartz re-feed → &f5 gold ingots&r."
		""
		"Submit &f10 gold ingots&r and &f8 quartz&r — proof the line runs."
		""
		"&7Downstream:&r Overcharged gold (Electronics) and CBC plates love a steady 5× gold bus."
		""
		"&7JEI:&r &fkubejs:ore_processing/gold_5x_mixing&7"
	]
	quest.8F01E00000000019.quest_subtitle: "Branch — gold 5×"
	quest.8F01E00000000019.title: "Gold Flux Refinery"
	quest.8F01E0000000001A.quest_desc: [
		"&eZinc branch&r — Create's early alloy metal, capped at &f3×&r in this pack (no 5× zinc)."
		""
		"2× smelt/blast crushed zinc → 2 ingots."
		"3× wash → 27 zinc nuggets + &fgunpowder&r (~25% chance)."
		""
		"Submit &f6 zinc ingots&r and &f4 gunpowder&r."
		""
		"&7Downstream:&r gunpowder feeds optional munitions — you don't need zombies for TNT anymore."
		""
		"&7JEI:&r &fkubejs:ore_processing/zinc_3x_splashing&7"
	]
	quest.8F01E0000000001A.quest_subtitle: "Branch — zinc 3×"
	quest.8F01E0000000001A.title: "Zinc & Gunpowder"
	quest.8F01E0000000001B.quest_desc: [
		"&eLead branch&r — TFMG ingot with a &afull 5× ladder&r."
		""
		"&72×&r — smelt/blast &fcreate:crushed_raw_lead&r"
		"&73×&r — wash → 27 lead nuggets + &ftfmg:sulfur_dust&r (~35%)"
		"&74×&r — heated mix: crushed + sulfur + water → &f4 ingots&r"
		"&75×&r — heated mix: crushed + &f#tfmg:flux&r + sulfur + water → &f5 ingots&r"
		""
		"Submit &f8 sulfur_dust&r and &f10 lead ingots&r."
		""
		"&7Downstream:&r sulfur feeds propellant, rubber chemistry, and munitions. CoE lead veins also return sulfur while drilling."
		""
		"&7JEI:&r &fkubejs:ore_processing/lead_5x_mixing&7"
	]
	quest.8F01E0000000001B.quest_subtitle: "Branch — lead 5×"
	quest.8F01E0000000001B.title: "Lead & Sulfur Loop"
	quest.8F01E0000000001C.quest_desc: [
		"&eNickel branch&r — parallel to lead with the same tier structure."
		""
		"3× wash drops &ftfmg:sulfur_dust&r (~25%). 4× and 5× mixing mirror lead (sulfur + flux + water)."
		""
		"Submit &f8 sulfur_dust&r and &f10 nickel ingots&r."
		""
		"&7Stainless and late TFMG recipes&r consume nickel — run this beside lead so sulfur stock stays balanced."
		""
		"&7JEI:&r &fkubejs:ore_processing/nickel_5x_mixing&7"
	]
	quest.8F01E0000000001C.quest_subtitle: "Branch — nickel 5×"
	quest.8F01E0000000001C.title: "Nickel & Sulfur Loop"
	quest.8F01E0000000001D.quest_desc: [
		"&eLithium branch&r — specialty metal for cooling and electrolysis, not a simple 5× mixer clone."
		""
		"&72×&r — smelt/blast &ftfmg:crushed_raw_lithium&r"
		"&73×&r — wash → 27 lithium nuggets + occasional water bucket byproduct"
		"&7Cooled mix&r — crushed + &ftfmg:cooling_fluid_bottle&r → 2 ingots (room-temp mixer)"
		"&7Vat electrolysis&r — 2× crushed + cooling fluid in a &fheated&r steel/firebrick vat with &ftwo electrodes&r → &f3 ingots&r"
		""
		"Submit &f6 lithium ingots&r and &f4 cooling fluid bottles&r."
		""
		"&7Downstream:&r cooling fluid is explicit petrochem crossover (plastic line) and diamond energiser billets."
		""
		"&7JEI:&r &fkubejs:ore_processing/lithium_vat_electrolysis&7"
	]
	quest.8F01E0000000001D.quest_subtitle: "Branch — lithium & cooling"
	quest.8F01E0000000001D.title: "Lithium Refinery"
	quest.8F01E0000000001E.quest_desc: [
		"Craft a &ecreateoreexcavation:vein_finder&r — stops the guesswork on buried veins."
		""
		"Right-click stone underground to sample; the finder points toward active deposit chunks. Pair with a &fvein atlas&r for co-op map marking."
		""
		"&71.&r Craft finder after your washing line is stable (drilling without processing wastes stress)"
		"&72.&r Scout for iron/copper/gold/leads/nickel/lithium vein types"
		"&73.&r Claim deposit chunks with &eFTB Chunks&r before building machines"
		""
		"&7Manual mining still works&r — automation should beat hand mining by mid-game, not day one."
	]
	quest.8F01E0000000001E.quest_subtitle: "Step 8 — vein scouting"
	quest.8F01E0000000001E.title: "Vein Finder"
	quest.8F01E0000000001F.quest_desc: [
		"Craft a &ecreateoreexcavation:drill&r — mounts on a mechanical bearing or drilling machine to chew veins."
		""
		"Drills output raw ore blocks or mod-specific raw items depending on vein type. Route outputs directly into crushing wheels."
		""
		"&71.&r Upgrade from hand mining once crushing/washing arrays exist"
		"&72.&r Feed drill RPM with a dedicated wind/water/engine line"
		"&73.&r Filter outputs so redstone/lapis/gem raw items hit the right sub-line"
		""
		"&7Diamond drill&r is a later speed upgrade — iron drill is enough to learn the loop."
	]
	quest.8F01E0000000001F.quest_subtitle: "Step 9 — mechanical drill"
	quest.8F01E0000000001F.title: "Ore Drill Head"
	quest.8F01E00000000020.quest_desc: [
		"Build a &ecreateoreexcavation:drilling_machine&r — the multiblock cap on vein extraction."
		""
		"Place on a valid vein, power it, and let raw ore ride a belt into your &fcrush → wash → flux&r megabus."
		""
		"&71.&r Align machine facing per JEI/ponder if stuck"
		"&72.&r Buffer output chests — drills spike throughput during high RPM"
		"&73.&r Force-load the vein chunk (FTB Chunks) on servers"
		""
		"&7This is the moment manual mining should lose forever&r — if you're still caving for iron, expand drilling first."
	]
	quest.8F01E00000000020.quest_subtitle: "Step 10 — drilling machine"
	quest.8F01E00000000020.title: "Vein Drilling Online"
	quest.8F01E00000000021.quest_desc: [
		"&eSpecialty ores&r — non-ingot materials from CoE raw items and vanilla lapis."
		""
		"Pack routes (see &fkubejs:ore_processing_special&7):"
		"&7• &fcreateoreexcavation:raw_redstone&r — crush → 6 dust; wash → 9 dust + glowstone chance"
		"&7• Lapis ore&r — crush/wash for bonus yields vs vanilla fortune mining"
		"&7• &fraw_diamond / raw_emerald&r — washing for gem output + XP nuggets"
		"&7• Coal&r — bonus crush yield"
		""
		"Submit &f16 raw redstone&r, &f16 lapis&r, and &f1 raw diamond&r as proof."
		""
		"&7These feeds bypass the ingot ladder&r but still love the same crushing/washing halls."
	]
	quest.8F01E00000000021.quest_subtitle: "Branch — gems & dusts"
	quest.8F01E00000000021.title: "Specialty Ore Processing"
	quest.8F01E00000000022.quest_desc: [
		"&eNext recommended wing: Petrochemicals&r — diesel engines want the metal and flux you're producing now."
		""
		"Oil discovery, pumpjacks, and distillation don't &frequire&r 5× ore, but steel plates and machine frames are easier with a flooded iron bus."
		""
		"Follow the quest link to &fWelcome — Petrochem Wing&r when your team is ready for liquid power."
		""
		"&7Optional now, core soon:&r most factories pivot to diesel + plastic mid-game."
	]
	quest.8F01E00000000022.quest_subtitle: "Optional — handoff to oil"
	quest.8F01E00000000022.title: "Next: Petrochem Wing"
	quest.8F01E00000000026.quest_desc: [
		"&aOre wing online!&r"
		""
		"You've proven at least one &elate ore path&r alongside the 5× iron milestone:"
		"&7• Lead/nickel sulfur loops for chemistry"
		"&7• Mechanical vein drilling replacing strip mines"
		"&7• Specialty gem/dust processing from CoE"
		""
		"Your factory should now export:"
		"&7• Ingots at 2×/3×/5× tiers"
		"&7• Flux (limesand) for petrochem + stone synthesis"
		"&7• Redstone, sulfur, gunpowder, clay, quartz byproducts"
		""
		"&7Recommended next pins:&r Petrochem welcome, then Electronics welcome when diesel is stable."
		""
		"Reward: experience + flux — go build the oil wing."
	]
	quest.8F01E00000000026.quest_subtitle: "Capstone — metal bus complete"
	quest.8F01E00000000026.title: "Ore Wing Capstone"
	quest.8F01F00000000010.quest_desc: [
		"&eStorage is factory infrastructure&r — ore tiers mean nothing if nuggets, fluids, and byproducts clog your floor."
		""
		"&7Tip:&r Pin this welcome node while you lay out chest rooms and cable runs."
		""
		"This chapter covers &athree complementary systems&r already in the pack:"
		"&7• &fSophisticated Storage&r — upgraded chests/barrels, stack upgrades, filters, compacting (nuggets → ingots in-place)"
		"&7• &fTom's Simple Storage&r — one terminal searches every linked inventory; interfaces hook Create belts"
		"&7• &fCreate buffers&r — item vaults, fluid tanks, smart chutes, stockpile switches for machine I/O"
		"&7• &fSophisticated Backpacks&r — mobile inventory with pickup, deposit, and restock for builders"
		""
		"&7Pack keybinds (see README):&r"
		"&7• &fB&r — open backpack"
		"&7• &f[&r / &f]&r — transfer to storage / inventory (Sophisticated)"
		"&7• Middle-click&r — sort storage"
		""
		"&7Recommended order:&r stand up Sophisticated chests early, add Tom's terminal before your second machine hall, vault fluids before petrochem."
		""
		"&7Quests never gate recipes&r — build whatever storage fits your base aesthetic."
	]
	quest.8F01F00000000010.quest_subtitle: "Chests → terminal → vaults → backpack"
	quest.8F01F00000000010.title: "Welcome — Storage Wing"
	quest.8F01F00000000011.quest_desc: [
		"Craft a &esophisticatedstorage:chest&r — your first proper factory drawer bank."
		""
		"Sophisticated chests accept &fupgrade cards&r in the side slots: bigger stacks, filtering, pickup, compacting, voiding, and more."
		""
		"&71.&r Place a labeled chest row beside your andesite machines"
		"&72.&r Right-click → upgrades tab to preview empty slots"
		"&73.&r Paint/name with an anvil if your team shares storage"
		""
		"&7Why not vanilla chests?&r you'll drown in nugget outputs from 3× washing — upgrades are the fix."
	]
	quest.8F01F00000000011.quest_subtitle: "Step 1 — first upgraded chest"
	quest.8F01F00000000011.title: "Sophisticated Chest"
	quest.8F01F00000000012.quest_desc: [
		"Upgrade to &esophisticatedstorage:copper_chest&r — higher slot count and upgrade capacity than wood tier."
		""
		"Copper chests are the sweet spot for &fearly ore bus&r storage: crushed iron, redstone byproduct, clay, sulfur."
		""
		"&71.&r Craft or tier-upgrade an existing chest (JEI shows copper tier recipe)"
		"&72.&r Dedicate one chest per material family — never mix crushed ore and finished ingots"
		""
		"&7Later tiers:&r iron → gold → diamond → netherite via tier upgrade items when throughput demands it."
	]
	quest.8F01F00000000012.quest_subtitle: "Step 2 — copper tier"
	quest.8F01F00000000012.title: "Copper Storage Tier"
	quest.8F01F00000000013.quest_desc: [
		"Install a &esophisticatedstorage:stack_upgrade_tier_1&r — multiplies how many items fit per slot."
		""
		"Stack upgrades are how you survive &f27-nugget wash batches&r without building 40 chests."
		""
		"&71.&r Insert upgrade in chest UI → upgrades tab"
		"&72.&r Higher stack tiers unlock as you reach iron/gold storage (check JEI)"
		"&73.&r Pair with &fcompact upgrades&r later so nuggets auto-fold into ingots"
		""
		"&7Co-op tip:&r only one player needs to craft upgrades; hand them like currency."
	]
	quest.8F01F00000000013.quest_subtitle: "Step 3 — stack upgrade"
	quest.8F01F00000000013.title: "Stack Upgrade Tier 1"
	quest.8F01F00000000014.quest_desc: [
		"Link chests into one searchable network with &esophisticatedstorage:controller&r + &foak_storage_connector&r."
		""
		"&7Controller&r aggregates every connected Sophisticated inventory on the network."
		"&7Storage connector&r (any wood variant) bridges chests/barrels across distances without merging slots manually."
		""
		"&71.&r Place controller in your storage room (one per network is enough early)"
		"&72.&r Attach connectors between chest rows"
		"&73.&r Open controller UI to search all linked items — treat it like mini-JEI for your base"
		""
		"&7Force-load&r the storage chunk on servers so auto-pickup upgrades keep working offline."
	]
	quest.8F01F00000000014.quest_subtitle: "Step 4 — linked network"
	quest.8F01F00000000014.title: "Controller & Connectors"
	quest.8F01F00000000015.quest_desc: [
		"Add a &esophisticatedstorage:filter_upgrade&r — slot-level or insert/extract filtering."
		""
		"Filters are how you stop &fcrushed copper&r from polluting your &fingot&r chest when belts misfeed."
		""
		"&71.&r Configure whitelist per chest (e.g. only #c:ingots/iron)"
		"&72.&r Use blacklist on void chests for cobble overflow"
		"&73.&r Advanced filter upgrade later adds NBT and mod-based rules"
		""
		"&7Pair with Create brass funnels&r on outputs for double protection."
	]
	quest.8F01F00000000015.quest_subtitle: "Step 5 — filtered slots"
	quest.8F01F00000000015.title: "Filter Upgrade"
	quest.8F01F00000000016.quest_desc: [
		"Install &esophisticatedstorage:compacting_upgrade&r — the ore chapter's best friend."
		""
		"Compacting automatically converts &f9 nuggets → 1 ingot&r (and similar recipes) inside the chest."
		""
		"&71.&r Put compacting on your wash output chest"
		"&72.&r Watch nuggets consolidate without a mechanical press line"
		"&73.&r Advanced compacting handles more recipes later"
		""
		"&7This is intentional parity&r — 3× washing floods nuggets; storage upgrades recover sanity."
	]
	quest.8F01F00000000016.quest_subtitle: "Step 6 — nugget compacting"
	quest.8F01F00000000016.title: "Compacting Upgrade"
	quest.8F01F00000000017.quest_desc: [
		"Place a &etoms_storage:inventory_connector&r — Tom's network master block."
		""
		"Any inventory touching the connector (chest, barrel, Sophisticated block, Create vault) joins the &fTom's network&r."
		""
		"&71.&r Put connector on your main storage wall"
		"&72.&r Run &ftoms_storage:inventory_cable&r if inventories are more than one block away"
		"&73.&r Use &finventory_configurator&r to link distant chests without moving them"
		""
		"&7Tom's and Sophisticated can coexist&r — many factories use Sophisticated for upgrades and Tom's for search."
	]
	quest.8F01F00000000017.quest_subtitle: "Branch — Tom's network start"
	quest.8F01F00000000017.title: "Inventory Connector"
	quest.8F01F00000000018.quest_desc: [
		"Craft a &etoms_storage:storage_terminal&r — one GUI for every linked inventory."
		""
		"Place terminal in your control room; search, move, and craft-pull items without running between chest rows."
		""
		"&71.&r Terminal must connect to the same network as your connector"
		"&72.&r Shift-click transfers respect inventory space on the far end"
		"&73.&r Add a second terminal upstairs when the megabase grows"
		""
		"&7JEI + terminal&r is the default late-game inventory UX for this pack."
	]
	quest.8F01F00000000018.quest_subtitle: "Branch — central terminal"
	quest.8F01F00000000018.title: "Storage Terminal Online"
	quest.8F01F00000000019.quest_desc: [
		"Hook Create logistics to Tom's with &finventory_interface&r + &fpolymorphic_item_filter&r."
		""
		"&7Interface&r exposes network items to belts, funnels, and hoppers on the outside face."
		"&7Polymorphic filter&r lets one interface serve multiple item types to smart chutes — great for mixed byproduct buses."
		""
		"&71.&r Place interface on a vault or chest face touching the network"
		"&72.&r Pipe a belt into the interface input"
		"&73.&r Configure filter slots for crushed ore families"
		""
		"&7This is the bridge&r between passive chest storage and active Create machine halls."
	]
	quest.8F01F00000000019.quest_subtitle: "Branch — Create bridge"
	quest.8F01F00000000019.title: "Interface & Polymorphic Filter"
	quest.8F01F0000000001A.quest_desc: [
		"Craft a &etoms_storage:wireless_terminal&r — remote access within range."
		""
		"Carry it while building so you never run back for brass, andesite, or redstone mid-scaffold."
		""
		"&71.&r Bind to your main network (configurator shows linked networks)"
		"&72.&r Advanced wireless terminal later for extended range"
		"&73.&r Keep one terminal in your backpack slot for megabase tours"
		""
		"&7Pack default:&r Tom's terminal key is unbound — set one in controls if you prefer keyboard over item use."
	]
	quest.8F01F0000000001A.quest_subtitle: "Branch — wireless pull"
	quest.8F01F0000000001A.title: "Wireless Terminal"
	quest.8F01F0000000001B.quest_desc: [
		"Place &f4× create:item_vault&r — bulk buffer for high-throughput machine outputs."
		""
		"Vaults are not searchable via Tom's until you attach an interface, but they excel at &fbelt buffering&r between crushing, washing, and smelting arrays."
		""
		"&71.&r Stack vaults vertically for dense storage per floor tile"
		"&72.&r Feed with chutes from above, extract with funnels below"
		"&73.&r Label with signs or Create display links"
	]
	quest.8F01F0000000001B.quest_subtitle: "Branch — Create item buffer"
	quest.8F01F0000000001B.title: "Item Vault Bank"
	quest.8F01F0000000001C.quest_desc: [
		"Build &f2× create:fluid_tank&r and a &fcreate:stockpile_switch&r — fluid and item threshold logic."
		""
		"Petrochem arrives soon; crude, diesel, and water need &fdedicated tank farms&r separate from item storage."
		""
		"&7Stockpile switch&r emits redstone when a vault/tank crosses a threshold — perfect for \"disable drill when buffer full\"."
		""
		"&71.&r Place tanks with blaze-burner clearance in mind"
		"&72.&r Pipe fluids with mechanical pumps or smart fluid pipes"
		"&73.&r Pair switch with redstone link for wireless machine pausing"
	]
	quest.8F01F0000000001C.quest_subtitle: "Branch — fluid buffers"
	quest.8F01F0000000001C.title: "Fluid Tanks & Stockpile Switch"
	quest.8F01F0000000001D.quest_desc: [
		"Precision I/O: &ecreate:smart_chute&r + &ecreate:brass_funnel&r."
		""
		"&7Smart chute&r holds a filter and respects redstone — use for single-item extraction from vaults."
		"&7Brass funnel&r pulls exact counts from inventories for recipe-perfect machine feeding."
		""
		"&71.&r Smart chute under wash output vault (iron nuggets only)"
		"&72.&r Brass funnel into mechanical mixer for 5× ore batches"
		"&73.&r Combine with Tom's interface for network-fed funnels"
	]
	quest.8F01F0000000001D.quest_subtitle: "Branch — precision logistics"
	quest.8F01F0000000001D.title: "Smart Chute & Brass Funnel"
	quest.8F01F0000000001E.quest_desc: [
		"Craft a &esophisticatedbackpacks:backpack&r — mobile storage for exploration and construction."
		""
		"Press &fB&r (pack default) to open. Upgrades install in the same UI pattern as chests."
		""
		"&71.&r Wear during vein scouting (Ore chapter)"
		"&72.&r Keep building blocks and tools in nested tabs once upgraded"
		"&73.&r Copper → iron → gold backpack tiers add slots and upgrade slots"
	]
	quest.8F01F0000000001E.quest_subtitle: "Branch — mobile inventory"
	quest.8F01F0000000001E.title: "Sophisticated Backpack"
	quest.8F01F0000000001F.quest_desc: [
		"Upgrade to &firon_backpack&r and add &fpickup_upgrade&r — vacuum loot while you build."
		""
		"Pickup respects filter upgrades — configure so you only collect cobble, andesite, or mob drops."
		""
		"&71.&r Install pickup in backpack upgrades tab"
		"&72.&r Toggle pickup with &fAlt+Z&r / &fAlt+X&r (pack default upgrade toggles)"
		"&73.&r Magnet upgrade later for larger radius"
	]
	quest.8F01F0000000001F.quest_subtitle: "Branch — iron tier + pickup"
	quest.8F01F0000000001F.title: "Iron Backpack & Pickup"
	quest.8F01F00000000020.quest_desc: [
		"Add &fdeposit_upgrade&r + &frestock_upgrade&r — two-way factory integration."
		""
		"&7Deposit&r dumps matching items from backpack into nearby inventories (great beside Tom's connector)."
		"&7Restock&r pulls items back when you run out while placing blocks."
		""
		"&71.&r Stand next to your main connector and deposit mined cobble"
		"&72.&r Restock andesite casing while wand-building"
		"&73.&r Crafting upgrade later for on-the-go part fabrication"
	]
	quest.8F01F00000000020.quest_subtitle: "Branch — deposit & restock"
	quest.8F01F00000000020.title: "Backpack Factory Link"
	quest.8F01F00000000022.quest_desc: [
		"&eNext recommended wing: Petrochemicals&r — you'll want fluid tanks and vault buffers before crude oil floods in."
		""
		"Follow the quest link when your item terminal can find ingots, flux, and sulfur without opening individual chests."
	]
	quest.8F01F00000000022.quest_subtitle: "Optional — handoff to oil"
	quest.8F01F00000000022.title: "Next: Petrochem Wing"
	quest.8F01F00000000026.quest_desc: [
		"&aStorage wing online!&r"
		""
		"You've proven at least one &elate logistics path&r:"
		"&7• Sophisticated compacting for ore nuggets"
		"&7• Tom's wireless terminal for remote pulls"
		"&7• Create smart chutes feeding machines from vaults"
		"&7• Backpack deposit/restock beside your connector"
		""
		"Your factory should now:"
		"&7• Search all items from one terminal"
		"&7• Buffer machine outputs without belt clog"
		"&7• Separate fluids before petrochem"
		"&7• Let builders restock without stealing from machine inputs"
		""
		"Reward: gold chest tier — start naming your bus chests like a real control room."
	]
	quest.8F01F00000000026.quest_subtitle: "Capstone — logistics complete"
	quest.8F01F00000000026.title: "Storage Wing Capstone"
	chapter_group.8F01A00000000002.title: "Petrochemicals"
	chapter_group.8F01B00000000002.title: "Electronics & Power"
	chapter_group.8F01C00000000002.title: "Architecture & Stone"
	chapter_group.8F01D00000000002.title: "Create Aeronautics"
	quest.8F01A00000000010.quest_desc: [
		"&ePetrochemicals unlock diesel power&r — TFMG crude oil, distillation towers, and the asphalt road line."
		""
		"&7Tip:&r Use &fPin Quest&r on this welcome node to keep oil steps on your HUD."
		""
		"This chapter walks &aoil discovery → pumpjack → distillation → diesel engines&r, then branches into plastics, coke, and a &f5-step asphalt chain&r for factory roads."
		""
		"&7Light fractions:&r crude distillation also yields &fLPG&r and &fpropylene&r — useful for tanks, reforming, and late chemistry side routes."
		""
		"&7Heat matters:&r distillation controllers need steel; vat recipes use heated/superheated mixing. Pair with your brass age and steel lines."
		""
		"&7Tip: Search JEI for &ftfmg:crude_oil&7 and &fkubejs:petrochem&7 to preview pack tweaks."
	]
	quest.8F01A00000000010.quest_subtitle: "Oil → diesel → asphalt"
	quest.8F01A00000000010.title: "Welcome — Petrochem Wing"
	quest.8F01A00000000011.quest_desc: [
		"Craft a &etfmg:surface_scanner&r — your first tool for finding underground oil deposits."
		""
		"Hold it and scan the overworld surface. Oil pools show as markers you can stake with a pumpjack later."
		""
		"&7Beginner tip:&r claim the chunk around your future oil field with &eFTB Chunks&r before building heavy machines."
	]
	quest.8F01A00000000011.quest_subtitle: "Step 1 — find oil"
	quest.8F01A00000000011.title: "Surface Scanner"
	quest.8F01A00000000012.quest_desc: [
		"Use the scanner until you locate a viable &ecrude oil deposit&r — usually deep overworld strata."
		""
		"Mark the spot, clear a flat pad, and plan pipe routes back to your main factory hall."
		""
		"&7No item gate&r — just confirm you found oil and are ready to build extraction."
	]
	quest.8F01A00000000012.quest_subtitle: "Step 2 — stake a deposit"
	quest.8F01A00000000012.title: "Oil Deposit Located"
	quest.8F01A00000000013.quest_desc: [
		"Place a &etfmg:pumpjack_base&r on your staked deposit and build the pumpjack tower above it."
		""
		"Route &fcrude oil&r into fluid tanks or pipes — this is your long-term liquid feedstock for diesel, plastics, and coke."
		""
		"&7Steel plates&r gate the distillation controller in this pack (lead plates are replaced)."
	]
	quest.8F01A00000000013.quest_subtitle: "Step 3 — start pumping"
	quest.8F01A00000000013.title: "Pumpjack Online"
	quest.8F01A00000000014.quest_desc: [
		"Stockpile &f4× tfmg:crude_oil_bucket&r from the pumpjack line."
		""
		"Crude is the root fluid — everything downstream (diesel, heavy oil, naphtha, asphalt) starts here."
		""
		"&7Pack tweak:&r crude distillation is &adiesel-biased&r vs vanilla TFMG splits."
	]
	quest.8F01A00000000014.quest_subtitle: "Step 4 — crude stockpile"
	quest.8F01A00000000014.title: "Crude Oil Reservoir"
	quest.8F01A00000000015.quest_desc: [
		"Craft a &etfmg:steel_distillation_controller&r and assemble a TFMG distillation tower."
		""
		"Feed crude (or heavy oil) into the tower with heat and rotation. Outputs split into &fdiesel, kerosene, heavy oil, naphtha, gasoline, LPG&r."
		""
		"&7Recipe ID:&r &fkubejs:petrochem/distillation/crude_oil"
	]
	quest.8F01A00000000015.quest_subtitle: "Step 5 — distillation tower"
	quest.8F01A00000000015.title: "Steel Distillation Controller"
	quest.8F01A00000000016.quest_desc: [
		"Collect &f2× tfmg:diesel_bucket&r from distillation — your primary liquid fuel for TFMG engines."
		""
		"Diesel powers &eregular engines&r, generators, and later radial engines. Route it in fluid pipes beside your Create shafts."
		""
		"&7Diesel also feeds&r munitions gasoline shells and factory propellant coke lines indirectly."
	]
	quest.8F01A00000000016.quest_subtitle: "Step 6 — diesel fuel"
	quest.8F01A00000000016.title: "Diesel Stockpile"
	quest.8F01A00000000017.quest_desc: [
		"Craft a &etfmg:regular_engine&r and couple it to a generator or machine that needs shaft power."
		""
		"Pipe diesel in, spin a flywheel, and you have &afactory-grade RPM&r independent of water wheels."
		""
		"&7First petrochem power milestone&r — scale engines before chasing radial/kero tiers."
	]
	quest.8F01A00000000017.quest_subtitle: "Step 7 — diesel engine online"
	quest.8F01A00000000017.title: "Regular Engine Running"
	quest.8F01A00000000018.quest_desc: [
		"Tap the &eheavy oil&r side stream from distillation — save at least one &ftfmg:heavy_oil_bucket&r."
		""
		"Heavy oil feeds three important branches:"
		"&7• Coking → &ftfmg:coal_coke&r (munitions + steel chemistry)"
		"&7• Compacting → &ftfmg:bitumen&r (asphalt chain)"
		"&7• Further distillation&r for lube and diesel recovery"
	]
	quest.8F01A00000000018.quest_subtitle: "Heavy oil side stream"
	quest.8F01A00000000018.title: "Heavy Oil Branch"
	quest.8F01A00000000019.quest_desc: [
		"Run naphtha through a &esteel/firebrick vat&r with superheated mixing to crack &fethylene&r."
		""
		"&7Recipe ID:&r &fkubejs:petrochem/catalytic_cracking"
		""
		"Ethylene is the gateway to &fplastic sheets&r, cooling fluid, and reactor casings later."
	]
	quest.8F01A00000000019.quest_subtitle: "Vat chemistry — heated"
	quest.8F01A00000000019.title: "Ethylene Cracking"
	quest.8F01A0000000001A.quest_desc: [
		"Process ethylene into &f4× tfmg:plastic_sheet&r — stock for circuit boards, reactor casings, and rubber recipes."
		""
		"Plastics tie petrochem to the &eelectronics chapter&r without hard-gating it."
		""
		"&7Keep a plastic bus&r on your fluid logistics network."
	]
	quest.8F01A0000000001A.quest_subtitle: "Petrochemical solids"
	quest.8F01A0000000001A.title: "Plastic Sheet Line"
	quest.8F01A0000000001B.quest_desc: [
		"Bottle &f2× tfmg:cooling_fluid_bottle&r from the plastic/chemistry line."
		""
		"Cooling fluid gates &egold and diamond energiser billets&r in Create New Age — plan ahead if you're chasing the reactor."
		""
		"&7Also used&r in advanced TFMG machine recipes."
	]
	quest.8F01A0000000001B.quest_subtitle: "Electronics crossover"
	quest.8F01A0000000001B.title: "Cooling Fluid Bottles"
	quest.8F01A0000000001C.quest_desc: [
		"Produce &f4× tfmg:rubber_sheet&r — gaskets, belts, and fluid-proof fittings for hot machine halls."
		""
		"Rubber pairs with plastics from the same ethylene tree."
	]
	quest.8F01A0000000001C.quest_subtitle: "Side branch — rubber"
	quest.8F01A0000000001C.title: "Rubber Sheets"
	quest.8F01A0000000001D.quest_desc: [
		"Coke &f2× tfmg:coal_coke&r in a superheated vat from heavy oil."
		""
		"&7Recipe ID:&r &fkubejs:petrochem/heavy_oil_coking"
		""
		"Coke feeds &efactory propellant, packed gunpowder, and scoria/basalt&r synthesis — a key mid-game byproduct."
	]
	quest.8F01A0000000001D.quest_subtitle: "Coking — superheated vat"
	quest.8F01A0000000001D.title: "Coal Coke from Heavy Oil"
	quest.8F01A0000000001E.quest_desc: [
		"Reform or distill into &ftfmg:kerosene_bucket&r — lighter fuel for radial engines and premium TFMG power."
		""
		"&7Recipe ID:&r &fkubejs:petrochem/premium_fuel_reforming&r (gasoline + sulfuric acid route)"
		""
		"Heavy oil re-distillation also yields kerosene — see &fHeavy Oil Re-Distillation&r."
		""
		"&7Note:&r Aeronautics &flevitite&r uses end stone powder + zinc — not kerosene directly."
	]
	quest.8F01A0000000001E.quest_subtitle: "Premium fuel tier"
	quest.8F01A0000000001E.title: "Kerosene Stockpile"
	quest.8F01A0000000001F.quest_desc: [
		"Upgrade to a &etfmg:radial_engine&r — kerosene/diesel-class power for large contraptions."
		""
		"Radial engines are your &ahigh-RPM petrochem cap&r before nuclear — pair with fluid valves and smart pipes from electronics."
	]
	quest.8F01A0000000001F.quest_subtitle: "Late petrochem power"
	quest.8F01A0000000001F.title: "Radial Engine Upgrade"
	quest.8F01A00000000020.quest_desc: [
		"&eStep 1/5 — bitumen&r: compact heavy oil into solid binder for factory roads."
		""
		"&7You need:&r heavy oil from distillation, a Create press, and &aheat&r (blaze burner)."
		""
		"&71.&r Pipe 1000 mB &ftfmg:heavy_oil&r into a &eMechanical Press&r"
		"&72.&r Heat the press — bitumen will not form cold"
		"&73.&r Output: &f4× tfmg:bitumen&r per batch"
		""
		"&cCommon mistakes:&r"
		"&7• Using a mixer instead of a press"
		"&7• Pouring crude or diesel — must be &fheavy oil&r"
		""
		"&7JEI:&r search &ftfmg:bitumen&7 or &fkubejs:petrochem&7"
	]
	quest.8F01A00000000020.quest_subtitle: "Asphalt 1/5 — bitumen"
	quest.8F01A00000000020.title: "Bitumen from Heavy Oil"
	quest.8F01A00000000021.quest_desc: [
		"&eStep 2/5 — dry road mix&r: combine bitumen with aggregate before melting."
		""
		"&7You need:&r bitumen from step 1, sand, gravel, a &eMechanical Mixer&r (no heat)."
		""
		"&71.&r Feed sand + gravel + bitumen into the mixer"
		"&72.&r Collect &f16× tfmg:asphalt_mixture&r — stockpile for the heated step"
		""
		"&cCommon mistakes:&r"
		"&7• Skipping this step and pouring bitumen straight into a basin"
		"&7• Running the mixer without enough aggregate — check JEI ratios"
		""
		"&7JEI:&r &ftfmg:asphalt_mixture&7"
	]
	quest.8F01A00000000021.quest_subtitle: "Asphalt 2/5 — dry mix"
	quest.8F01A00000000021.title: "Asphalt Mixture"
	quest.8F01A00000000022.quest_desc: [
		"&eStep 3/5 — hot pour&r: melt road mix into castable liquid asphalt."
		""
		"&7You need:&r asphalt_mixture, water, &eMechanical Mixer&r, and &aheat&r."
		""
		"&71.&r 1× asphalt_mixture + 250 mB water → 1000 mB &ftfmg:liquid_asphalt&r"
		"&72.&r Bucket the fluid or pipe it to your casting line"
		""
		"&cCommon mistakes:&r"
		"&7• Forgetting &aheat&r on the mixer — recipe silently fails or stalls"
		"&7• Expecting a solid block from the mixer — output is &ffluid only&r"
		""
		"&7JEI:&r &fkubejs:petrochem/mixing/liquid_asphalt&7"
	]
	quest.8F01A00000000022.quest_subtitle: "Asphalt 3/5 — hot liquid"
	quest.8F01A00000000022.title: "Liquid Asphalt"
	quest.8F01A00000000023.quest_desc: [
		"&eStep 4/5 — casting setup&r: build the TFMG asphalt caster (not a Create basin)."
		""
		"&7You need:&r &ftfmg:casting_basin&r, a &fminecraft:hopper&r &bunder&r the basin, and liquid asphalt piping."
		""
		"&71.&r Craft and place &ftfmg:casting_basin&r — &cnot&r create:basin or any other mod basin"
		"&72.&r Put a &fhopper underneath&r to collect finished blocks"
		"&73.&r Pipe or bucket &f250+ mB liquid_asphalt&r into the basin (144 mB per block cast)"
		"&74.&r Wait a few seconds — asphalt block drops into the hopper"
		""
		"&cCommon mistakes:&r"
		"&7• No hopper below — casting looks &fstuck&r with nowhere for output to go"
		"&7• Pouring heavy oil or bitumen instead of &fliquid asphalt&r fluid"
		"&7• Using Create's basin — this pack uses &fTFMG casting&r for roads"
		""
		"&7JEI:&r &ftfmg:casting_basin&7 · fallback compacting &fkubejs:petrochem/compacting/asphalt&7"
		"&7Cross-chapter:&r Architecture &fAsphalt Factory Roads&r reuses these blocks."
	]
	quest.8F01A00000000023.quest_subtitle: "Asphalt 4/5 — casting setup"
	quest.8F01A00000000023.title: "Casting Basin + Hopper"
	quest.8F01A00000000024.quest_desc: [
		"&eStep 5/5 — paved roads&r: cast solid asphalt blocks for factory floors."
		""
		"&7You need:&r working casting basin line from step 4, steady liquid asphalt supply."
		""
		"&71.&r Run the basin until you hold &f8× tfmg:asphalt&r blocks"
		"&72.&r Lay them between ore processing, distillation, and FTB-claimed chunks"
