	quest.8F01A00000000028.title: "Heavy Oil Re-Distillation"
	quest.8F01A00000000029.quest_desc: [
		"&eLPG side stream&r — light gas fraction from crude distillation."
		""
		"&7You need:&r crude oil tower running; bucket or tank the &ftfmg:lpg&r output."
