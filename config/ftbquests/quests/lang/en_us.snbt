	quest.8F01C00000000029.quest_subtitle: "Phase 1 — shaped stone"
	quest.8F01C00000000029.title: "Stone Brick Facade"
	quest.8F01C0000000002A.quest_desc: [
		"&eTerracotta batch&r — smelt clay for colored factory accents."
		""
		"&71.&r Automate clay from gravel+sand compacting or dripstone byproducts"
		"&72.&r Smelt → &f8× terracotta&r (any color works for this quest)"
		"&73.&r Dye in heated mixers later for themed halls"
		""
		"&7Create Deco&r colored bricks can piggyback on terracotta + stone brick lines."
	]
	quest.8F01C0000000002A.quest_subtitle: "Phase 1 — terracotta"
	quest.8F01C0000000002A.title: "Terracotta Batch"
	quest.8F01C0000000002B.quest_desc: [
		"&eDripstone crystallization&r — heated calcite + water in a mixer."
		""
		"&7You need:&r calcite from lithification, &aheated&r mixer, 1000 mB water."
		""
		"&71.&r 4× calcite + water → &f2× dripstone_block&r per batch"
