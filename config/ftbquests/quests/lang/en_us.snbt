	quest.8F01A00000000026.quest_subtitle: "Capstone — fuels & roads"
	quest.8F01A00000000026.title: "Petrochem Capstone"
	quest.8F01A00000000027.quest_desc: [
		"&eCatalytic flux cracker&r — superheated vat chemistry that turns naphtha into ethylene."
		""
		"&7You need:&r &ftfmg:steel_vat&r or &ftfmg:firebrick_lined_vat&r, &bminimum 2×2 vat footprint&r, naphtha, &ftfmg:flux&r (ore processing), water."
		""
		"&71.&r Build a vat multiblock with mixing machine inside"
		"&72.&r Pipe 500 mB naphtha + flux + water into the vat"
		"&73.&r Superheat and run &fkubejs:petrochem/catalytic_cracking&r"
		"&74.&r Mark complete when you understand the flux + vat size requirement"
		""
		"&cCommon mistakes:&r"
		"&7• Vat too small — recipe needs &fmin_size: 2&r"
		"&7• No flux — crush+wash ore for flux byproducts"
		""
		"&7JEI:&r &fkubejs:petrochem/catalytic_cracking&7"
	]
	quest.8F01A00000000027.quest_subtitle: "Optional — flux + vat cracking"
	quest.8F01A00000000027.title: "Catalytic Flux Cracker"
	quest.8F01A00000000028.quest_desc: [
		"&eHeavy oil second pass&r — feed heavy oil back through the distillation tower for lube and light fractions."
		""
