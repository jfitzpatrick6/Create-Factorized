	quest.8F01C00000000014.title: "Gravel Aggregate"
	quest.8F01C00000000015.quest_desc: [
		"Collect &f16× minecraft:sand&r — sandstone sediments and asphalt-adjacent mixes."
		""
		"Crushing gravel → sand is the vanilla Create route (not duplicated by KubeJS)."
	]
	quest.8F01C00000000015.quest_subtitle: "Step 5 — sand"
	quest.8F01C00000000015.title: "Sand Aggregate"
	quest.8F01C00000000016.quest_desc: [
		"Craft a &eminecraft:stonecutter&r — slice base stones into stairs, walls, and polished variants."
		""
		"Place it beside your mixer output chest for instant detailing."
	]
	quest.8F01C00000000016.quest_subtitle: "Step 6 — stonecutter bench"
	quest.8F01C00000000016.title: "Stonecutter Online"
	quest.8F01C00000000017.quest_desc: [
		"Synthesize or mine &f16× minecraft:andesite&r — early facades and mixer filler."
		""
		"Andesite is in the &fkubejs:lithified_stone_inputs&r tag for bulk recipes."
	]
	quest.8F01C00000000017.quest_subtitle: "Step 7 — andesite"
	quest.8F01C00000000017.title: "Andesite Palette"
	quest.8F01C00000000018.quest_desc: [
		"&eStep 8 — calcite lithification&r: heated mixer turns sandstone into calcite."
		""
		"&7You need:&r sandstone, bone meal, &ftfmg:flux&r (from ore processing), water, &aheated&r mixer."
		""
		"&71.&r 2× sandstone + 4× bone meal + flux + 500 mB water → &f2× calcite&r"
		"&72.&r Stock &f8× calcite&r for dripstone and limestone chains"
		""
		"&cCommon mistakes:&r"
		"&7• Running unheated — recipe needs &aheated&r mixing"
		"&7• No flux — crush+wash ore to get flux byproducts (see ore processing quests)"
		""
		"&7JEI:&r &fkubejs:building_stones/calcite_lithification&7"
		""
		"Calcite unlocks dripstone farms and Create limestone sediments."
	]
	quest.8F01C00000000018.quest_subtitle: "Step 8 — calcite"
	quest.8F01C00000000018.title: "Calcite Line"
	quest.8F01C00000000019.quest_desc: [
		"&eStep 9 — deepslate&r: superheated lithification — hardest heat gate in Phase 2 stone."
		""
		"&7You need:&r stone, charcoal, &ftfmg:flux&r, lava, &csuperheated&r mixer (blaze cake or nether fuel)."
		""
		"&71.&r 4× stone + 2× charcoal + flux + 250 mB lava → &f4× cobbled_deepslate&r"
		"&72.&r Smelt to deepslate for polished factory walls; stock &f8× cobbled&r"
		""
		"&cCommon mistakes:&r"
		"&7• Using only &aheated&r — deepslate requires &csuperheated&r"
		"&7• Forgetting flux — same ore-wash byproduct as calcite"
		""
		"&7JEI:&r &fkubejs:building_stones/cobbled_deepslate_lithification&7"
	]
	quest.8F01C00000000019.quest_subtitle: "Step 9 — deepslate"
	quest.8F01C00000000019.title: "Cobbled Deepslate"
	quest.8F01C0000000001A.quest_desc: [
		"&eStep 10 — tuff compaction&r: compactor recipe, no heat required."
		""
		"&7You need:&r gravel, clay balls, cobblestone, &eMechanical Compactor&r."
		""
		"&71.&r 2× gravel + 2× clay + 2× cobble → &f4× tuff&r per batch"
		"&72.&r Collect &f8× tuff&r for facade palettes"
		""
		"&cCommon mistakes:&r"
		"&7• Trying to mix tuff in a mixer — this route is &fcompactor-only&r"
		""
		"&7JEI:&r &fkubejs:building_stones/tuff_compaction&7"
	]
	quest.8F01C0000000001A.quest_subtitle: "Step 10 — tuff"
	quest.8F01C0000000001A.title: "Tuff Palette"
	quest.8F01C0000000001B.quest_desc: [
		"&ePhase 3 — limestone sediment&r: heated mix ties calcite to Create worldgen stone."
		""
		"&7You need:&r sandstone, calcite, water, &aheated&r mixer."
		""
		"&71.&r Heated mix → &f8× create:limestone&r"
		"&72.&r Limestone begins asurine, veridium, and ochrum branches"
		""
		"&cCommon mistakes:&r"
		"&7• Skipping calcite quest — limestone chain needs calcite input"
		""
		"&7JEI:&r &fkubejs:building_stones/limestone_sediment&7"
	]
	quest.8F01C0000000001B.quest_subtitle: "Phase 3 — Create limestone"
	quest.8F01C0000000001B.title: "Limestone Sediment"
	quest.8F01C0000000001C.quest_desc: [
		"&ePhase 3 — scoria volcanic mix&r: superheated basalt + coke chemistry."
		""
		"&7You need:&r basalt, &ftfmg:coal_coke&r (petrochem), magma cream, &csuperheated&r mixer."
		""
		"&71.&r 2× basalt + coal coke + magma cream → &f2× scoria&r"
		"&72.&r Stock &f8× scoria&r; leads to scorchia and crimsite"
		""
		"&cCommon mistakes:&r"
		"&7• Using charcoal instead of &fcoal coke&r"
		"&7• Unheated mixer — scoria needs &csuperheated&r"
		""
		"&7JEI:&r &fkubejs:building_stones/scoria_volcanic&7"
		""
		"&7Cross-chapter:&r Petrochemicals coke line supplies coal coke."
	]
	quest.8F01C0000000001C.quest_subtitle: "Phase 3 — scoria"
	quest.8F01C0000000001C.title: "Scoria Volcanic Mix"
	quest.8F01C0000000001D.quest_desc: [
		"Stonecut &fcreate:cut_limestone&r — the chapter icon and showcase block."
		""
		"Cut variants feed Chipped and Rechiseled benches for hundreds of facades."
	]
	quest.8F01C0000000001D.quest_subtitle: "Detailing — cut stone"
	quest.8F01C0000000001D.title: "Cut Limestone"
	quest.8F01C0000000001E.quest_desc: [
		"Place a &echipped:botanist_workbench&r — mass-variant stone from one input block."
		""
		"Feed andesite, limestone, or deepslate for themed panels without hand-placing every texture."
	]
	quest.8F01C0000000001E.quest_subtitle: "Chipped workstation"
	quest.8F01C0000000001E.title: "Chipped Botanist Bench"
	quest.8F01C00000000027.quest_desc: [
		"&eChipped showcase&r: one bench, hundreds of stone variants — no need to craft eight different blocks."
		""
		"&7You need:&r &fchipped:botanist_workbench&r from the prior quest, any stone palette (andesite, limestone, deepslate)."
		""
		"&71.&r Place the workbench in your build hall"
		"&72.&r Feed one stone type and browse variant previews in the UI"
		"&73.&r Manually place &fat least one&r Chipped variant on a test wall"
		"&74.&r Mark complete when you understand the workflow — honor-system checkmark"
		""
		"&cCommon mistakes:&r"
		"&7• Hand-crafting every variant — Chipped is meant to &fbrowse-and-pick&r"
		""
		"&7JEI:&r search &fchipped&7 for workbench recipes"
		""
		"Pair with Rechiseled in the next quest for mixed industrial facades."
	]
	quest.8F01C00000000027.quest_subtitle: "Detailing — variant showcase"
	quest.8F01C00000000027.title: "A Thousand Faces"
	quest.8F01C0000000001F.quest_desc: [
		"Craft a &erechiseled:chisel&r — in-world rechiseling for alternate block faces."
