	quest.8F01C00000000031.quest_desc: [
		"&eMain Street&r — pave a factory artery with at least 32 facade blocks."
		""
		"&7You need:&r asphalt, stone bricks, Chipped panels, or any mixed palette from this chapter."
		""
		"&71.&r Pick a straight factory route between two machine halls"
		"&72.&r Place &fat least 32 blocks&r of paving/facade along it"
		"&73.&r Mark complete when your team has a recognizable main street — honor checkmark"
		""
		"&7Co-op tip:&r claim the street chunks before wand-paving with friends."
	]
	quest.8F01C00000000031.quest_subtitle: "Megabase — main artery"
	quest.8F01C00000000031.title: "Main Street Paving"
	quest.8F01C00000000032.quest_desc: [
		"&ePalette Master&r — stock one block from each of ten automated stone families."
		""
		"Submit a single sample of each family in your inventory — proof your geology line covers the full pack palette."
		""
		"&7Families:&r cobble, stone, andesite, calcite, deepslate, tuff, limestone, basalt, scoria, cut limestone."
		""
		"Once complete, Chipped and Rechiseled can run continuously without mining trips."
	]
	quest.8F01C00000000032.quest_subtitle: "Milestone — ten stone families"
	quest.8F01C00000000032.title: "Palette Master"
	quest.8F01D00000000010.quest_desc: [
		"&eCreate Aeronautics&r — optional mobility after your factory has diesel and basic electronics."
		""
		"&bLeft branch:&r build your &ffirst diesel car&r with &eCreate Offroad&r wheels on a &fSimulated&r contraption — &cnot&r a cart assembler."
		"&bCenter branch:&r craft &frock cutting wheels&r and borehead bearings for mobile tunnel miners."
		"&bRight branch:&r optional &fgyroscopic flight&r with levitite fuel."
		""
		"&7Prerequisites:&r Petrochem diesel, brass/electronics for transmissions and steering."
		""
		"Nothing here gates recipes, power, or the nuclear reactor — pure factory QoL."
	]
	quest.8F01D00000000010.quest_subtitle: "Cars, mining wheels \& optional flight"
	quest.8F01D00000000010.title: "Welcome — Create Aeronautics"
	quest.8F01D00000000020.quest_desc: [
		"&eStep 1 — physics assembler&r: ground vehicles use &fCreate Simulated&r, not minecart contraptions."
		""
		"&71.&r Craft &fsimulated:physics_assembler&r (andesite casing + lever + andesite alloy)"
		"&72.&r Plan a small frame: wheel mounts, engine block, steering wheel, seat"
		"&73.&r Glue blocks together, then right-click the assembler to launch the build"
		""
		"&cCommon mistake:&r using &fcreate:cart_assembler&r — Offroad cars need the physics assembler."
	]
	quest.8F01D00000000020.quest_subtitle: "Car 1/11 — physics assembler"
	quest.8F01D00000000020.title: "Physics Assembler"
	quest.8F01D00000000021.quest_desc: [
		"&eStep 2 — glue the frame&r: &fcreate:super_glue&r groups blocks into one Simulated contraption."
		""
		"&71.&r Glue chassis blocks, wheel mounts, engine mounts, and seat platform into one structure"
		"&72.&r Leave room for shafts between engine and wheel mounts"
		"&73.&r Do &fnot&r glue the physics assembler itself — it launches the build"
		""
		"&cCommon mistake:&r forgetting glue on wheel mounts — they shear off on the first bump."
	]
	quest.8F01D00000000021.quest_subtitle: "Car 2/11 — super glue"
	quest.8F01D00000000021.title: "Glued Chassis"
	quest.8F01D00000000022.quest_desc: [
		"&eStep 3 — suspension springs&r: &foffroad:wheel_mount&r recipes need &fsimulated:spring&r."
		""
		"&71.&r Craft at least &f2× simulated:spring&r"
		"&72.&r Stock them for wheel mount crafting and optional suspension tuning"
		""
		"&7Create Simulated&r is bundled with Aeronautics — springs also help test contraptions on the ground."
	]
	quest.8F01D00000000022.quest_subtitle: "Car 3/11 — springs"
	quest.8F01D00000000022.title: "Suspension Springs"
	quest.8F01D00000000023.quest_desc: [
		"&eStep 4 — wheel mounts&r: &foffroad:wheel_mount&r is the hub for tires, brakes, and steering."
		""
		"&7Recipe:&r andesite casing + iron sheet + simulated:spring."
		""
		"&71.&r Craft &f2× offroad:wheel_mount&r (4 for a proper car)"
		"&72.&r Glue mounts to the chassis with output facing the ground"
		"&73.&r Power from &ftop&r = brakes; power from &fside&r = steer that wheel"
	]
	quest.8F01D00000000023.quest_subtitle: "Car 4/11 — wheel mounts"
	quest.8F01D00000000023.title: "Wheel Mounts"
	quest.8F01D00000000024.quest_desc: [
		"&eStep 5 — tires&r: right-click a wheel mount with &foffroad:tire&r to seat the wheel."
		""
		"&7Recipe:&r shaft + dried kelp ring — kelp farms from Factory Canteen work great here."
		""
		"&71.&r Craft &f2× offroad:tire&r minimum (4 recommended)"
		"&72.&r R-click each tire onto a wheel mount face"
		"&73.&r Confirm wheels spin freely when the contraption is assembled"
	]
	quest.8F01D00000000024.quest_subtitle: "Car 5/11 — road tires"
	quest.8F01D00000000024.title: "Tires Mounted"
	quest.8F01D00000000025.quest_desc: [
		"&eStep 6 — diesel engine&r: &ftfmg:regular_engine&r turns fuel into rotation for your drivetrain."
		""
		"&7You need:&r diesel from &cPetrochemicals&r, engine cylinders, and a shaft output to the wheels."
		""
		"&71.&r Build/assemble the engine per TFMG ponder (cylinders, shaft, air + fuel pipes, exhaust)"
		"&72.&r Glue the engine block to the chassis"
		"&73.&r Pipe &ftfmg:diesel&r in and route &fCO₂&r to an exhaust"
		""
		"&7JEI:&r search &ftfmg:regular_engine&r for the full assembly diagram."
	]
	quest.8F01D00000000025.quest_subtitle: "Car 6/11 — diesel engine"
	quest.8F01D00000000025.title: "Regular Engine Installed"
	quest.8F01D00000000026.quest_desc: [
		"&eStep 7 — analog transmission&r: &fsimulated:analog_transmission&r couples engine RPM to your wheel shafts."
		""
		"&7Recipe needs:&r brass casing, shaft, cogwheel, electron tube."
		""
		"&71.&r Craft &fsimulated:analog_transmission&r"
		"&72.&r Place on the shaft line between engine and wheel mounts"
		"&73.&r Shift gears with redstone or a linked controller per JEI ponder"
	]
	quest.8F01D00000000026.quest_subtitle: "Car 7/11 — analog transmission"
	quest.8F01D00000000026.title: "Analog Transmission"
	quest.8F01D00000000027.quest_desc: [
		"&eStep 8 — steering wheel&r: &fsimulated:steering_wheel&r is the driver's control surface."
		""
		"&7Recipe:&r large cogwheel + andesite casing + shaft."
		""
		"&71.&r Craft &fsimulated:steering_wheel&r"
		"&72.&r Glue it within reach of the driver seat"
		"&73.&r Wire redstone from the wheel to wheel-mount sides for steering"
	]
	quest.8F01D00000000027.quest_subtitle: "Car 8/11 — steering wheel"
	quest.8F01D00000000027.title: "Steering Wheel"
	quest.8F01D00000000028.quest_desc: [
		"&eStep 9 — driver seat&r: &fcreate:white_seat&r (any dye works) anchors you to the moving contraption."
		""
		"&71.&r Glue a seat behind the steering wheel"
		"&72.&r Right-click to sit before assembling on the physics assembler"
		"&73.&r Passengers can use additional seats on the same glued frame"
	]
	quest.8F01D00000000028.quest_subtitle: "Car 9/11 — driver seat"
	quest.8F01D00000000028.title: "Driver Seat"
	quest.8F01D00000000029.quest_desc: [
		"&eStep 10 — fuel hookup&r: pipe diesel from your petrochem tanks into the engine."
		""
		"&71.&r Run fluid pipes (or portable tanks) to the engine fuel port"
		"&72.&r Stock at least one bucket of diesel on board for the first test drive"
		"&73.&r Verify exhaust/CO₂ has somewhere to go — stalled exhaust kills RPM"
		""
		"&7Flat test lot:&r claim a chunk with FTB Chunks so the contraption stays loaded."
	]
	quest.8F01D00000000029.quest_subtitle: "Car 10/11 — diesel fuel line"
	quest.8F01D00000000029.title: "Fuel Tank Hookup"
	quest.8F01D0000000002D.quest_desc: [
		"&eStep 11 — assemble \& drive&r: launch the glued frame from the physics assembler."
		""
		"&71.&r Sit in the driver seat"
		"&72.&r Right-click the &fsimulated:physics_assembler&r to assemble the contraption"
		"&73.&r Start the TFMG engine and shift the analog transmission"
		"&74.&r Steer with the &fsimulated:steering_wheel&r — brakes from wheel-mount tops"
		""
		"&7Disassemble:&r park on flat ground and break the assembler lever to recover blocks."
	]
	quest.8F01D0000000002D.quest_subtitle: "Car 11/11 — assemble \& drive"
	quest.8F01D0000000002D.title: "Assemble \& Test Drive"
	quest.8F01D0000000002E.quest_desc: [
		"&aFirst car complete!&r"
		""
		"You built a diesel Simulated contraption with Offroad tires, TFMG power, and a steering wheel."
		""
		"&7Next upgrades:&r 4-wheel steering, asphalt roads from Petrochem, rock cutting wheels in the center branch, optional gyro flight on the right."
		""
		"Reward: spare &foffroad:tire&r for the garage shelf."
	]
	quest.8F01D0000000002E.quest_subtitle: "Capstone — first factory car"
	quest.8F01D0000000002E.title: "My First Factory Car"
	quest.8F01D00000000030.quest_desc: [
		"&eRock cutting wheels&r replace road tires on wheel mounts for mobile mining."
		""
		"&7Recipe:&r crushing wheel + industrial iron block + iron sheet → &foffroad:rockcutting_wheel&r"
		""
		"&71.&r Craft at least &f2× offroad:rockcutting_wheel&r"
		"&72.&r Right-click them onto &foffroad:wheel_mount&r faces — same as tires"
		"&73.&r Spinning wheels break blocks ahead of the contraption"
		""
		"&7Video guide:&r &bhttps://www.youtube.com/watch?v=RJhzMu_NA0Q&r"
	]
	quest.8F01D00000000030.quest_subtitle: "Mining 1/4 — rock cutting wheels"
	quest.8F01D00000000030.title: "Rock Cutting Wheels"
	quest.8F01D00000000031.quest_desc: [
		"&eBorehead bearing&r — dedicated mining bearing for tunnel boring machines."
		""
		"&7Recipe:&r wooden slab + gearbox + industrial iron block."
		""
		"&71.&r Craft &foffroad:borehead_bearing&r"
		"&72.&r Mount on a glued Simulated frame with rock cutting wheels attached"
		"&73.&r Feed rotation from your engine line — bearing speed limits max bore rate"
		""
		"Pair with chests or portable storage interfaces to collect mined blocks."
	]
	quest.8F01D00000000031.quest_subtitle: "Mining 2/4 — borehead bearing"
	quest.8F01D00000000031.title: "Borehead Bearing"
	quest.8F01D00000000032.quest_desc: [
		"&eMount the mining rig&r: glue rock cutting wheels, borehead bearing, engine, and storage."
		""
		"&71.&r Build a narrow frame that fits your target tunnel size"
		"&72.&r Attach &f2–4 rockcutting wheels&r to wheel mounts on the front face"
		"&73.&r Add a borehead bearing as the rotation anchor if building a TBM layout"
		"&74.&r Claim chunks along the bore path so the rig stays loaded"
		""
		"&7Video guide:&r &bhttps://www.youtube.com/watch?v=RJhzMu_NA0Q&r"
	]
	quest.8F01D00000000032.quest_subtitle: "Mining 3/4 — rig layout"
	quest.8F01D00000000032.title: "Mining Rig Assembled"
	quest.8F01D00000000033.quest_desc: [
		"&aTunnel bore online!&r"
		""
		"Drive or power your mining contraption through stone — collected blocks land in onboard storage."
		""
		"&7Mark complete&r after your first successful bore run — honor-system checkmark."
		""
		"Great for linking distant ore outposts to your main factory bus."
	]
	quest.8F01D00000000033.quest_subtitle: "Mining 4/4 — first bore run"
	quest.8F01D00000000033.title: "Rock Cutting Capstone"
	quest.8F01D00000000011.quest_desc: [
		"Craft &ecreate:brass_casing&r — lightweight structural skin for airship hulls and engine nacelles."
		""
		"Brass should already flow from your andesite → brass age line."
	]
	quest.8F01D00000000011.quest_subtitle: "Step 1 — brass airframe"
	quest.8F01D00000000011.title: "Brass Casing"
	quest.8F01D00000000012.quest_desc: [
		"Keep a &ecreate:hand_crank&r handy for bench testing propeller bearings before you commit FE or diesel."
		""
		"Spin bearings safely on the ground first — tune RPM with a rotation speed controller if needed."
	]
	quest.8F01D00000000012.quest_subtitle: "Step 2 — bench testing"
	quest.8F01D00000000012.title: "Hand Crank Test Rig"
	quest.8F01D00000000013.quest_desc: [
		"&eFTB Chunks&r — claim airspace approach lanes and your hangar pad on the team map."
		""
		"Open map (&bdefault: M&r), claim chunks around the runway, and enable chunk loading if your server allows."
		""
		"Prevents friendly grief and keeps contraptions loaded during co-op flights."
	]
	quest.8F01D00000000013.quest_subtitle: "Step 3 — claim sky base"
	quest.8F01D00000000013.title: "Chunk-Claimed Hangar"
	quest.8F01D00000000014.quest_desc: [
		"Craft &faeronautics:gyroscopic_propeller_bearing&r — the core gyroscopic flight block."
		""
		"Mount on a balanced brass frame; add propellers per JEI structure hints."
		""
		"&7This item is the mod's signature&r — treat it like a Create bearing with lift."
	]
	quest.8F01D00000000014.quest_subtitle: "Step 4 — gyro bearing"
	quest.8F01D00000000014.title: "Gyroscopic Propeller Bearing"
	quest.8F01D0000000001B.quest_desc: [
		"&eEnd stone powder&r — crush end stone for levitite blend mixing."
		""
		"&7You need:&r &fminecraft:end_stone&r (End expedition or trading), Create crushing wheels."
		""
		"&71.&r Crush end stone → &faeronautics:end_stone_powder&r (50% byproduct chance)"
		"&72.&r Stock &f4× powder&r for one levitite batch"
		""
		"&7JEI:&r &faeronautics:crushing/end_stone_powder&7"
	]
	quest.8F01D0000000001B.quest_subtitle: "Step 4b — end powder"
	quest.8F01D0000000001B.title: "End Stone Powder"
	quest.8F01D0000000001C.quest_desc: [
		"&eRechiseled airframe skin&r — optional compat blocks for lighter-looking hulls."
		""
		"The &fcreate-aeronautics-rechiseled-compat&r mod lets Rechiseled stone panels count as valid aeronautics structure blocks."
		""
		"&71.&r Craft or stonecut a Rechiseled panel (e.g. &fstone_smooth_large_tiles&r)"
		"&72.&r Swap plain brass/stone on your bearing frame for Rechiseled facades"
		"&73.&r Mark complete when your airframe has a themed skin — honor checkmark"
		""
		"&7Purely cosmetic&r — flight physics unchanged."
	]
	quest.8F01D0000000001C.quest_subtitle: "Optional — rechiseled hull"
	quest.8F01D0000000001C.title: "Rechiseled Airframe Skin"
	quest.8F01D00000000015.quest_desc: [
		"&eLevitite blend&r — heated mixer fuel for gyroscopic bearings."
		""
		"&7You need:&r &f4× aeronautics:end_stone_powder&r, &f2× create:zinc_nugget&r, 500 mB water, &aheated&r mixer."
		""
		"&71.&r Mix in a heated mechanical mixer → &f500 mB aeronautics:levitite_blend&r"
		"&72.&r Bucket with &faeronautics:levitite_blend_bucket&r"
		"&73.&r Pipe into the bearing assembly before your first manned test hop"
		""
		"&cCommon mistakes:&r"
		"&7• Expecting kerosene or LPG — levitite is an &fend-stone + zinc&r recipe, not a petrochem fluid"
		""
		"&7JEI:&r &faeronautics:mixing/levitite_blend&7"
	]
	quest.8F01D00000000015.quest_subtitle: "Step 5 — levitite fuel"
	quest.8F01D00000000015.title: "Levitite Blend Tank"
	quest.8F01D00000000016.quest_desc: [
		"&eStep 6 — shakedown flight&r: first manned hop with levitite fuel and a balanced frame."
		""
		"&7You need:&r working gyro bearing, levitite in the assembly, claimed chunks, flat test area."
		""
		"&71.&r Bench-spin the bearing with hand crank — confirm no wobble"
		"&72.&r Pipe levitite into the bearing per JEI hints"
		"&73.&r Lift off, translate ~50 blocks, land on the same pad"
		"&74.&r Mark complete when your team trusts the contraption — honor-system checkmark"
		""
		"&cCommon mistakes:&r"
		"&7• Unbalanced brass frame — add counterweight blocks"
		"&7• Flying out of loaded chunks — claim approach lanes first"
		""
		"&7Co-op:&r one player pilots, another tends fuel pipes and chunk loaders."
	]
	quest.8F01D00000000016.quest_subtitle: "Step 6 — first hop"
	quest.8F01D00000000016.title: "Shakedown Flight"
	quest.8F01D00000000017.quest_desc: [
		"&eStep 7 — helipad&r: flat touchdown surface reduces gyro bearing wobble."
		""
		"&7You need:&r at least &f5×5 smooth_stone&r (smelt stone twice), or asphalt taxiways from petrochem."
		""
		"&71.&r Clear trees and slopes within one chunk of the pad"
		"&72.&r Lay smooth stone in a flat 5×5 (or larger) square"
		"&73.&r Mark complete when the pad is flight-ready — honor-system checkmark"
		""
		"&cCommon mistakes:&r"
		"&7• Landing on grass or slabs — uneven blocks amplify bearing shake"
		""
		"Asphalt from &cPetrochemicals&r also works for taxiways; smooth stone is the cheap starter helipad."
	]
	quest.8F01D00000000017.quest_subtitle: "Step 7 — helipad"
	quest.8F01D00000000017.title: "Smooth Stone Landing Pad"
	quest.8F01D00000000018.quest_desc: [
		"&eStep 8 — team stash&r: communal flight gear beside the helipad."
		""
		"&7You need:&r a labeled chest, spare fuel buckets, optional aviator goggles."
		""
		"&71.&r Place a chest within 5 blocks of the landing pad"
		"&72.&r Stock levitite buckets, spare propellers, and repair materials"
		"&73.&r Label it for co-op visitors — honor-system checkmark"
		""
		"&cCommon mistakes:&r"
		"&7• Stash too far from pad — pilots scramble mid-emergency"
		""
		"&7Friend-server flavor:&r label the chest so visitors know flight gear is communal."
	]
	quest.8F01D00000000018.quest_subtitle: "Step 8 — team stash"
	quest.8F01D00000000018.title: "Co-op Hangar Chest"
	quest.8F01D00000000019.quest_desc: [
		"&eStep 9 — co-op sky tour&r: ferry a friend or scout distant chunks together."
		""
		"&7You need:&r working bearing, fueled assembly, claimed route chunks, a willing passenger."
		""
		"&71.&r Pick a destination — ore outpost, buddy's build, or scenic landmark"
		"&72.&r Fly there and back without dismantling the contraption"
		"&73.&r Mark complete after a successful group flight — honor-system checkmark"
		""
		"&cCommon mistakes:&r"
		"&7• Solo joyride only — this step is meant for &fco-op&r server flavor"
		""
		"&eFlight is tourism&r — not required for any recipe in the pack."
	]
	quest.8F01D00000000019.quest_subtitle: "Step 9 — friend server joyride"
	quest.8F01D00000000019.title: "Co-op Sky Tour"
	quest.8F01D0000000001A.quest_desc: [
		"&aAeronautics wing complete!&r"
		""
		"Gyro bearing + levitite + claimed chunks = comfortable co-op mobility."
		""
		"Return to ground factories anytime — the nuclear grid still does the real work."
		""
		"Reward: &faeronautics:aviators_goggles&r for the pilot who logs the most hours."
	]
	quest.8F01D0000000001A.quest_subtitle: "Capstone — optional aviator"
